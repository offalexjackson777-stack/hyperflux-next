      "cache_inputs": [
        "Cargo.lock",
        "Cargo.toml",
        "crates/**/*.rs",
        "driver/kernel/**/*",
        "integrations/**/*",
        "packaging/**/*",
        "runtime/linux.json",
        "schemas/*.json",
        "sdk/**/*",
        "tools/hfxdev/install.py",
        "tools/hfxdev/package_pipeline.py"
      ],
      "produced_evidence": [
        "package-build-manifest",
        "installed-files-inventory",
        "reproducible-payload-digest"
      ],
      "resume_policy": "rerun"
    }
  ]
}
