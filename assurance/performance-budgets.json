{
  "$schema": "../schemas/performance-budgets.schema.json",
  "schema": "hyperflux-performance-budgets-v1",
  "metrics": [
    {
      "id": "bridge-actor-response-timeout",
      "title": "Maximum configured bridge actor response timeout",
      "measurement_kind": "json-pointer",
      "source": "runtime/linux.json",
      "selector": "/bridge/timing/actor_response_timeout_ms",
      "unit": "milliseconds",
      "maximum": 30000,
      "status": "enforced-software",
      "sample_count": 1,
      "warmup_count": 0,
      "release_blocking": true,
      "rationale": "A bounded timeout prevents one failed client exchange from waiting indefinitely."
    },
    {
      "id": "bridge-command-queue-capacity",
      "title": "Bridge command queue capacity",
      "measurement_kind": "json-pointer",
      "source": "runtime/linux.json",
      "selector": "/bridge/limits/command_queue_capacity",
      "unit": "count",
      "maximum": 128,
      "status": "enforced-software",
      "sample_count": 1,
      "warmup_count": 0,
      "release_blocking": true,
      "rationale": "Backpressure must stay explicit and memory use must remain bounded."
    },
    {
      "id": "bridge-event-capacity",
      "title": "Bridge event history capacity",
      "measurement_kind": "json-pointer",
      "source": "runtime/linux.json",
      "selector": "/bridge/limits/event_capacity",
      "unit": "count",
      "maximum": 512,
      "status": "enforced-software",
      "sample_count": 1,
      "warmup_count": 0,
      "release_blocking": false,
      "rationale": "Diagnostics remain useful without becoming an unbounded journal."
    },
    {
      "id": "protocol-message-size",
      "title": "Maximum bridge protocol message",
      "measurement_kind": "json-pointer",
      "source": "protocol/v5/catalog.json",
      "selector": "/limits/max_message_bytes",
      "unit": "bytes",
      "maximum": 1048576,
      "status": "enforced-software",
      "sample_count": 1,
      "warmup_count": 0,
      "release_blocking": true,
      "rationale": "The framing boundary rejects oversized messages before allocation or decoding."
    },
    {
      "id": "bridge-binary-size",
      "title": "Installed bridge executable size",
      "measurement_kind": "artifact-size",
      "source": "packaging/install.json",
      "selector": "bridge-daemon",
      "unit": "bytes",
      "maximum": 12000000,
      "status": "enforced-software",
      "sample_count": 1,
      "warmup_count": 0,
      "release_blocking": true,
      "rationale": "Unexpected binary growth is surfaced before packaging."
    },
    {
      "id": "operations-cli-size",
      "title": "Installed operations CLI size",
      "measurement_kind": "artifact-size",
      "source": "packaging/install.json",
      "selector": "operations-cli",
      "unit": "bytes",
      "maximum": 10000000,
      "status": "enforced-software",
      "sample_count": 1,
      "warmup_count": 0,
      "release_blocking": false,
      "rationale": "Doctor and support tooling should not grow without review."
    },
    {
      "id": "activation-utility-size",
      "title": "Installed activation utility size",
      "measurement_kind": "artifact-size",
      "source": "packaging/install.json",
      "selector": "activation-utility",
      "unit": "bytes",
      "maximum": 10000000,
      "status": "enforced-software",
      "sample_count": 1,
      "warmup_count": 0,
      "release_blocking": false,
      "rationale": "The activation helper remains a bounded operational component."
    },
    {
      "id": "openrgb-module-size",
      "title": "OpenRGB native module size",
      "measurement_kind": "artifact-size",
      "source": "packaging/install.json",
      "selector": "openrgb-native",
      "unit": "bytes",
      "maximum": 4000000,
      "status": "enforced-software",
      "sample_count": 1,
      "warmup_count": 0,
      "release_blocking": false,
      "rationale": "Upstream registry reuse must not silently turn the adapter into an oversized application fork."
    },
    {
      "id": "staged-payload-size",
      "title": "Canonical uncompressed installed payload size",
      "measurement_kind": "staged-payload-size",
      "source": "packaging/install.json",
      "selector": "complete-root",
      "unit": "bytes",
      "maximum": 45000000,
      "status": "enforced-software",
      "sample_count": 1,
      "warmup_count": 0,
      "release_blocking": true,
      "rationale": "The complete optional-adapter payload has a reviewed upper bound before native compression."
    },
    {
      "id": "effect-frame-visible-delay",
      "title": "Visible effect-frame delay at the device",
      "measurement_kind": "physical",
      "source": "assurance/performance-budgets.json",
      "selector": "qualified-effect-stream",
      "unit": "milliseconds",
      "maximum": 50,
      "status": "blocked-by-physical-evidence",
      "sample_count": 300,
      "warmup_count": 60,
      "release_blocking": true,
      "rationale": "A software-only transport test cannot prove that a real Rainbow Wave remains visually smooth."
    },
    {
      "id": "receiver-reconnect-recovery",
      "title": "Qualified controller recovery after receiver reconnect",
      "measurement_kind": "physical",
      "source": "assurance/performance-budgets.json",
      "selector": "qualified-reconnect",
      "unit": "milliseconds",
      "maximum": 2000,
      "status": "blocked-by-physical-evidence",
      "sample_count": 10,
      "warmup_count": 1,
      "release_blocking": true,
      "rationale": "Recovery includes real USB enumeration, fresh generation qualification, and application re-registration."
    },
    {
      "id": "bridge-ready-after-service-start",
      "title": "Bridge readiness after service start",
      "measurement_kind": "physical",
      "source": "assurance/performance-budgets.json",
      "selector": "installed-service-start",
      "unit": "milliseconds",
      "maximum": 1000,
      "status": "blocked-by-physical-evidence",
      "sample_count": 20,
      "warmup_count": 2,
      "release_blocking": true,
      "rationale": "Installed startup includes permissions, kernel surfaces, profile loading, and socket readiness."
    },
    {
      "id": "steady-effect-cpu",
      "title": "Bridge CPU use during a steady two-device software effect",
      "measurement_kind": "physical",
      "source": "assurance/performance-budgets.json",
      "selector": "qualified-two-device-effect",
      "unit": "percent",
      "maximum": 5,
      "status": "blocked-by-physical-evidence",
      "sample_count": 60,
      "warmup_count": 10,
      "release_blocking": false,
      "rationale": "A sustained effect must not consume unreasonable host resources."
    },
    {
      "id": "steady-bridge-memory",
      "title": "Bridge resident memory during a steady two-device effect",
      "measurement_kind": "physical",
      "source": "assurance/performance-budgets.json",
      "selector": "qualified-two-device-effect",
      "unit": "bytes",
      "maximum": 67108864,
      "status": "blocked-by-physical-evidence",
      "sample_count": 60,
      "warmup_count": 10,
      "release_blocking": false,
      "rationale": "Bounded queues and histories should keep steady-state memory comfortably below 64 MiB."
    }
  ]
}
