        "repository": "actions/upload-artifact",
        "version": "v7.0.1",
        "commit": "043fb46d1a93c77aae656e7c1c64a875d1fc6a0a",
        "license_expression": "MIT"
      },
      {
        "id": "upload-pages-artifact",
        "repository": "actions/upload-pages-artifact",
