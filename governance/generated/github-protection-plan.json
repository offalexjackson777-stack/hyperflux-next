{
  "apply_authorized": false,
  "default_branch": "main",
  "excluded_components": [
    "pages-deployment",
    "release-tags",
    "release-publication",
    "hardware-ci"
  ],
  "remote_state": "not-created",
  "repository": "offalexjackson777-stack/hyperflux-next",
  "ruleset": {
    "dismiss_stale_reviews": true,
    "enforcement": "active-after-explicit-remote-authorization",
    "require_code_owner_reviews": true,
    "require_conversation_resolution": true,
    "require_linear_history": true,
    "required_approvals": 1,
    "required_status_checks": [
      "CodeQL / Analyze (c-cpp)",
      "CodeQL / Analyze (python)",
      "Dependency review / Dependency review",
      "Verification / Fast software"
    ]
  },
  "schema": "hyperflux-github-protection-plan-v1"
}
