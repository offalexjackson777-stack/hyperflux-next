{
  "$schema": "../schemas/protocol-catalog.schema.json",
  "schema": "hyperflux-protocol-catalog-v1",
  "minimum_version": 1,
  "maximum_version": 1,
  "features": ["ownership-leases", "atomic-transactions", "event-subscriptions", "structured-diagnostics"],
  "records": [
    {
      "name": "EmptyRequest",
      "description": "A method request with no method-specific fields.",
      "fields": []
    },
    {
      "name": "RgbColor",
      "description": "One canonical eight-bit RGB color.",
      "fields": [
        {"name": "red", "type": "ColorChannel", "required": true, "many": false, "max_items": null, "description": "Red channel."},
        {"name": "green", "type": "ColorChannel", "required": true, "many": false, "max_items": null, "description": "Green channel."},
        {"name": "blue", "type": "ColorChannel", "required": true, "many": false, "max_items": null, "description": "Blue channel."}
      ]
    },
    {
      "name": "ClientHello",
      "description": "Bounded client protocol and feature offer.",
      "fields": [
        {"name": "client_id", "type": "ClientId", "required": true, "many": false, "max_items": null, "description": "Process-scoped client identity."},
        {"name": "client_name", "type": "ClientName", "required": true, "many": false, "max_items": null, "description": "User-facing application name."},
        {"name": "minimum_version", "type": "ProtocolVersion", "required": true, "many": false, "max_items": null, "description": "Oldest protocol accepted by the client."},
        {"name": "maximum_version", "type": "ProtocolVersion", "required": true, "many": false, "max_items": null, "description": "Newest protocol accepted by the client."},
        {"name": "requested_features", "type": "CapabilityId", "required": true, "many": true, "max_items": 64, "description": "Optional SDK features requested by the client."}
      ]
    },
    {
      "name": "ServerHello",
      "description": "Negotiated protocol version and bridge feature set.",
      "fields": [
        {"name": "selected_version", "type": "ProtocolVersion", "required": true, "many": false, "max_items": null, "description": "Mutually supported protocol version."},
        {"name": "bridge_version", "type": "ComponentVersion", "required": true, "many": false, "max_items": null, "description": "Bridge component version."},
        {"name": "enabled_features", "type": "CapabilityId", "required": true, "many": true, "max_items": 64, "description": "Features enabled for this connection."},
        {"name": "event_buffer_capacity", "type": "QueueCapacity", "required": true, "many": false, "max_items": null, "description": "Maximum retained event count."}
      ]
    },
    {
      "name": "ResourceKey",
      "description": "One device-scoped writable resource.",
      "fields": [
        {"name": "device_id", "type": "LogicalDeviceId", "required": true, "many": false, "max_items": null, "description": "Logical resource owner."},
        {"name": "kind", "type": "ResourceKind", "required": true, "many": false, "max_items": null, "description": "Generic resource domain."}
      ]
    },
    {
      "name": "LeaseRequest",
      "description": "Atomic request for one or more writable resources.",
      "fields": [
        {"name": "request_id", "type": "RequestId", "required": true, "many": false, "max_items": null, "description": "Idempotency identity."},
        {"name": "client_id", "type": "ClientId", "required": true, "many": false, "max_items": null, "description": "Requesting client."},
        {"name": "resources", "type": "ResourceKey", "required": true, "many": true, "max_items": 32, "description": "Complete atomic resource set."},
        {"name": "duration_ms", "type": "LeaseDurationMs", "required": true, "many": false, "max_items": null, "description": "Renewable lease duration."}
      ]
    },
    {
      "name": "LeaseGrant",
      "description": "Granted ownership lease.",
      "fields": [
        {"name": "lease_id", "type": "LeaseId", "required": true, "many": false, "max_items": null, "description": "Lease identity."},
        {"name": "client_id", "type": "ClientId", "required": true, "many": false, "max_items": null, "description": "Owning client."},
        {"name": "resources", "type": "ResourceKey", "required": true, "many": true, "max_items": 32, "description": "Atomically owned resources."},
        {"name": "expires_at_ms", "type": "MonotonicMs", "required": true, "many": false, "max_items": null, "description": "Exclusive monotonic expiry."},
        {"name": "state", "type": "LeaseState", "required": true, "many": false, "max_items": null, "description": "Current lease state."}
      ]
    },
    {
      "name": "LeaseResult",
      "description": "Atomic lease decision with bounded conflict detail.",
      "fields": [
        {"name": "outcome", "type": "LeaseOutcome", "required": true, "many": false, "max_items": null, "description": "Lease decision."},
        {"name": "grant", "type": "LeaseGrant", "required": false, "many": false, "max_items": null, "description": "Grant when ownership succeeds."},
        {"name": "conflicting_client", "type": "ClientId", "required": false, "many": false, "max_items": null, "description": "Current owner when known."},
        {"name": "conflicting_resource", "type": "ResourceKey", "required": false, "many": false, "max_items": null, "description": "First deterministic conflict."}
      ]
    },
    {
      "name": "LeaseAction",
      "description": "Renewal or release of one existing lease.",
      "fields": [
        {"name": "request_id", "type": "RequestId", "required": true, "many": false, "max_items": null, "description": "Idempotency identity."},
        {"name": "client_id", "type": "ClientId", "required": true, "many": false, "max_items": null, "description": "Owning client."},
        {"name": "lease_id", "type": "LeaseId", "required": true, "many": false, "max_items": null, "description": "Lease to change."},
        {"name": "duration_ms", "type": "LeaseDurationMs", "required": false, "many": false, "max_items": null, "description": "New duration for renewal."}
      ]
    },
    {
      "name": "LogicalDeviceSnapshot",
      "description": "Application-neutral logical controller state.",
      "fields": [
        {"name": "device_id", "type": "LogicalDeviceId", "required": true, "many": false, "max_items": null, "description": "Logical identity."},
        {"name": "device_kind", "type": "DeviceKind", "required": true, "many": false, "max_items": null, "description": "Device category."},
        {"name": "product_id", "type": "ProductId", "required": true, "many": false, "max_items": null, "description": "Observed product id."},
        {"name": "profile_id", "type": "ProfileId", "required": false, "many": false, "max_items": null, "description": "Qualified profile when available."},
        {"name": "presence", "type": "PresenceState", "required": true, "many": false, "max_items": null, "description": "Derived controller presence."},
        {"name": "connection_mode", "type": "ConnectionMode", "required": true, "many": false, "max_items": null, "description": "Current route mode."},
        {"name": "support_level", "type": "SupportLevel", "required": true, "many": false, "max_items": null, "description": "Evidence-backed support level."},
        {"name": "battery_percent", "type": "BatteryPercent", "required": false, "many": false, "max_items": null, "description": "Latest valid battery value."},
        {"name": "capabilities", "type": "CapabilityId", "required": true, "many": true, "max_items": 128, "description": "Qualified semantic capabilities."}
      ]
    },
    {
      "name": "ReceiverSnapshot",
      "description": "Generation-bound receiver and child inventory.",
      "fields": [
        {"name": "receiver_id", "type": "ReceiverId", "required": true, "many": false, "max_items": null, "description": "Logical receiver identity."},
        {"name": "generation_id", "type": "GenerationId", "required": true, "many": false, "max_items": null, "description": "Current receiver generation."},
        {"name": "lifecycle", "type": "ReceiverLifecycleState", "required": true, "many": false, "max_items": null, "description": "Receiver lifecycle state."},
        {"name": "devices", "type": "LogicalDeviceSnapshot", "required": true, "many": true, "max_items": 32, "description": "Independent logical children."},
        {"name": "stable_restore_enabled", "type": "Boolean", "required": true, "many": false, "max_items": null, "description": "Whether stable state restoration is enabled."}
      ]
    },
    {
      "name": "BridgeSnapshot",
      "description": "Sequence-bound complete bridge snapshot.",
      "fields": [
        {"name": "sequence", "type": "SequenceNumber", "required": true, "many": false, "max_items": null, "description": "Latest event sequence reflected by this snapshot."},
        {"name": "receivers", "type": "ReceiverSnapshot", "required": true, "many": true, "max_items": 16, "description": "Registered receiver generations."}
      ]
    },
    {
      "name": "LightingFrame",
      "description": "One logical-device direct-mode frame.",
      "fields": [
        {"name": "device_id", "type": "LogicalDeviceId", "required": true, "many": false, "max_items": null, "description": "Frame target."},
        {"name": "frame_index", "type": "FrameIndex", "required": true, "many": false, "max_items": null, "description": "Transaction-local frame order."},
        {"name": "colors", "type": "RgbColor", "required": true, "many": true, "max_items": 4096, "description": "Logical LED colors before carrier translation."}
      ]
    },
    {
      "name": "TransactionRequest",
      "description": "Atomic generation- and ownership-bound operation.",
      "fields": [
        {"name": "request_id", "type": "RequestId", "required": true, "many": false, "max_items": null, "description": "Idempotency identity."},
        {"name": "transaction_id", "type": "TransactionId", "required": true, "many": false, "max_items": null, "description": "Transaction identity."},
        {"name": "client_id", "type": "ClientId", "required": true, "many": false, "max_items": null, "description": "Submitting client."},
        {"name": "lease_id", "type": "LeaseId", "required": true, "many": false, "max_items": null, "description": "Atomic ownership proof."},
        {"name": "receiver_id", "type": "ReceiverId", "required": true, "many": false, "max_items": null, "description": "Receiver target."},
        {"name": "generation_id", "type": "GenerationId", "required": true, "many": false, "max_items": null, "description": "Generation binding."},
        {"name": "transaction_class", "type": "TransactionClass", "required": true, "many": false, "max_items": null, "description": "Ordering and coalescing class."},
        {"name": "deadline_ms", "type": "MonotonicMs", "required": true, "many": false, "max_items": null, "description": "Absolute monotonic deadline."},
        {"name": "resources", "type": "ResourceKey", "required": true, "many": true, "max_items": 32, "description": "Complete ownership set."},
        {"name": "frames", "type": "LightingFrame", "required": true, "many": true, "max_items": 32, "description": "Complete atomic frame batch."}
      ]
    },
    {
      "name": "TransactionResult",
      "description": "Terminal or current transaction state.",
      "fields": [
        {"name": "transaction_id", "type": "TransactionId", "required": true, "many": false, "max_items": null, "description": "Transaction identity."},
        {"name": "state", "type": "TransactionState", "required": true, "many": false, "max_items": null, "description": "Explicit transaction state."},
        {"name": "delivered_frames", "type": "DeliveredFrameCount", "required": true, "many": false, "max_items": null, "description": "Terminally delivered frames."},
        {"name": "side_effect_certainty", "type": "SideEffectCertainty", "required": true, "many": false, "max_items": null, "description": "What transport side effects are known after termination."},
        {"name": "live_write_executed", "type": "Boolean", "required": true, "many": false, "max_items": null, "description": "Whether transport began a hardware write."},
        {"name": "automatic_retry", "type": "Boolean", "required": true, "many": false, "max_items": null, "description": "Always false after possible transport."},
        {"name": "device_application_confirmed", "type": "Boolean", "required": true, "many": false, "max_items": null, "description": "Whether separate evidence confirms child application."},
        {"name": "error_kind", "type": "ProtocolErrorKind", "required": false, "many": false, "max_items": null, "description": "Structured failure class."}
      ]
    },
    {
      "name": "TransactionLookup",
      "description": "Idempotent lookup of one previously submitted transaction.",
      "fields": [
        {"name": "request_id", "type": "RequestId", "required": true, "many": false, "max_items": null, "description": "Lookup request identity."},
        {"name": "client_id", "type": "ClientId", "required": true, "many": false, "max_items": null, "description": "Original transaction owner."},
        {"name": "transaction_id", "type": "TransactionId", "required": true, "many": false, "max_items": null, "description": "Transaction to inspect."}
      ]
    },
    {
      "name": "SubscriptionRequest",
      "description": "Bounded event subscription cursor.",
      "fields": [
        {"name": "client_id", "type": "ClientId", "required": true, "many": false, "max_items": null, "description": "Subscribing client."},
        {"name": "after_sequence", "type": "SequenceNumber", "required": true, "many": false, "max_items": null, "description": "Last sequence already observed."}
      ]
    },
    {
      "name": "BridgeEvent",
      "description": "Sequence-bound typed event with snapshot references.",
      "fields": [
        {"name": "sequence", "type": "SequenceNumber", "required": true, "many": false, "max_items": null, "description": "Strictly increasing sequence."},
        {"name": "kind", "type": "EventKind", "required": true, "many": false, "max_items": null, "description": "Typed event category."},
        {"name": "receiver_id", "type": "ReceiverId", "required": false, "many": false, "max_items": null, "description": "Affected receiver when applicable."},
        {"name": "generation_id", "type": "GenerationId", "required": false, "many": false, "max_items": null, "description": "Affected generation when applicable."},
        {"name": "device_id", "type": "LogicalDeviceId", "required": false, "many": false, "max_items": null, "description": "Affected logical device when applicable."},
        {"name": "lease_id", "type": "LeaseId", "required": false, "many": false, "max_items": null, "description": "Affected lease when applicable."},
        {"name": "transaction_id", "type": "TransactionId", "required": false, "many": false, "max_items": null, "description": "Affected transaction when applicable."},
        {"name": "finding_id", "type": "FindingId", "required": false, "many": false, "max_items": null, "description": "Affected finding when applicable."}
      ]
    },
    {
      "name": "EventBatch",
      "description": "Bounded event result with explicit cursor-gap state.",
      "fields": [
        {"name": "subscription_id", "type": "SubscriptionId", "required": true, "many": false, "max_items": null, "description": "Subscription identity."},
        {"name": "stream_id", "type": "StreamId", "required": true, "many": false, "max_items": null, "description": "Bridge event-stream identity."},
        {"name": "stream_epoch", "type": "StreamEpoch", "required": true, "many": false, "max_items": null, "description": "Changes whenever the event stream restarts."},
        {"name": "projection_revision", "type": "ProjectionRevision", "required": true, "many": false, "max_items": null, "description": "Snapshot projection contract revision."},
        {"name": "events", "type": "BridgeEvent", "required": true, "many": true, "max_items": 256, "description": "Events after the requested cursor."},
        {"name": "oldest_available", "type": "SequenceNumber", "required": true, "many": false, "max_items": null, "description": "Oldest retained sequence."},
        {"name": "latest_available", "type": "SequenceNumber", "required": true, "many": false, "max_items": null, "description": "Newest retained sequence."},
        {"name": "dropped_events", "type": "DroppedEventCount", "required": true, "many": false, "max_items": null, "description": "Events evicted since this stream epoch began."},
        {"name": "cursor_gap", "type": "Boolean", "required": true, "many": false, "max_items": null, "description": "Whether the client must refresh its snapshot."}
      ]
    },
    {
      "name": "DiagnosticFinding",
      "description": "One privacy-classified actionable finding.",
      "fields": [
        {"name": "finding_id", "type": "FindingId", "required": true, "many": false, "max_items": null, "description": "Stable finding code."},
        {"name": "severity", "type": "ErrorSeverity", "required": true, "many": false, "max_items": null, "description": "User-facing severity."},
        {"name": "cause", "type": "HumanMessage", "required": true, "many": false, "max_items": null, "description": "Bounded technical cause."},
        {"name": "explanation", "type": "HumanMessage", "required": true, "many": false, "max_items": null, "description": "Plain user explanation."},
        {"name": "safe_action", "type": "HumanMessage", "required": true, "many": false, "max_items": null, "description": "One safe remediation."},
        {"name": "privacy", "type": "PrivacyClass", "required": true, "many": false, "max_items": null, "description": "Support-output privacy class."},
        {"name": "documentation", "type": "DocumentationPath", "required": true, "many": false, "max_items": null, "description": "Stable documentation path."}
      ]
    },
    {
      "name": "DiagnosticSnapshot",
      "description": "Bounded bridge findings and queue health.",
      "fields": [
        {"name": "sequence", "type": "SequenceNumber", "required": true, "many": false, "max_items": null, "description": "Latest reflected event sequence."},
        {"name": "findings", "type": "DiagnosticFinding", "required": true, "many": true, "max_items": 128, "description": "Active actionable findings."},
        {"name": "event_buffer_capacity", "type": "QueueCapacity", "required": true, "many": false, "max_items": null, "description": "Configured event bound."},
        {"name": "transaction_queue_capacity", "type": "QueueCapacity", "required": true, "many": false, "max_items": null, "description": "Configured transaction bound."}
      ]
    },
    {
      "name": "RpcError",
      "description": "Stable structured request failure.",
      "fields": [
        {"name": "request_id", "type": "RequestId", "required": false, "many": false, "max_items": null, "description": "Related request when parsing reached it."},
        {"name": "kind", "type": "ProtocolErrorKind", "required": true, "many": false, "max_items": null, "description": "Machine-readable failure class."},
        {"name": "message", "type": "HumanMessage", "required": true, "many": false, "max_items": null, "description": "Bounded user-safe explanation."},
        {"name": "finding_id", "type": "FindingId", "required": true, "many": false, "max_items": null, "description": "Diagnostic catalog reference."}
      ]
    }
  ],
  "methods": [
    {"name": "negotiate", "request": "ClientHello", "response": "ServerHello", "required_feature": null, "description": "Select one compatible protocol version and optional feature set."},
    {"name": "snapshot", "request": "EmptyRequest", "response": "BridgeSnapshot", "required_feature": null, "description": "Read one sequence-bound complete logical-device snapshot."},
    {"name": "acquire-lease", "request": "LeaseRequest", "response": "LeaseResult", "required_feature": "ownership-leases", "description": "Acquire a complete resource set atomically."},
    {"name": "renew-lease", "request": "LeaseAction", "response": "LeaseResult", "required_feature": "ownership-leases", "description": "Renew one owned lease."},
    {"name": "release-lease", "request": "LeaseAction", "response": "LeaseResult", "required_feature": "ownership-leases", "description": "Release one owned lease without forced takeover."},
    {"name": "submit-transaction", "request": "TransactionRequest", "response": "TransactionResult", "required_feature": "atomic-transactions", "description": "Submit one complete generation-bound transaction."},
    {"name": "transaction-outcome", "request": "TransactionLookup", "response": "TransactionResult", "required_feature": "atomic-transactions", "description": "Resolve a prior result without resubmitting transport."},
    {"name": "subscribe", "request": "SubscriptionRequest", "response": "EventBatch", "required_feature": "event-subscriptions", "description": "Read bounded typed events after a sequence cursor."},
    {"name": "diagnostics", "request": "EmptyRequest", "response": "DiagnosticSnapshot", "required_feature": "structured-diagnostics", "description": "Read privacy-classified diagnostics and queue health."}
  ]
}
