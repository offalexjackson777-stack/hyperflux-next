{
  "$schema": "../../schemas/protocol-catalog.schema.json",
  "schema": "hyperflux-protocol-catalog-v1",
  "minimum_version": 2,
  "maximum_version": 2,
  "limits": {
    "max_message_bytes": 1048576,
    "max_json_depth": 128
  },
  "features": ["ownership-leases", "atomic-transactions", "profile-bound-transactions", "event-subscriptions", "structured-diagnostics"],
  "records": [
    {
      "name": "EmptyRequest",
      "description": "A method request with no method-specific fields.",
      "fields": []
    },
    {
      "name": "RgbColor",
      "description": "One canonical eight-bit RGB color.",
      "fields": [
        {"name": "red", "type": "ColorChannel", "required": true, "many": false, "max_items": null, "description": "Red channel."},
        {"name": "green", "type": "ColorChannel", "required": true, "many": false, "max_items": null, "description": "Green channel."},
        {"name": "blue", "type": "ColorChannel", "required": true, "many": false, "max_items": null, "description": "Blue channel."}
      ]
    },
    {
      "name": "ClientHello",
      "description": "Bounded client protocol and feature offer.",
      "fields": [
        {"name": "client_id", "type": "ClientId", "required": true, "many": false, "max_items": null, "description": "Process-scoped client identity."},
        {"name": "client_name", "type": "ClientName", "required": true, "many": false, "max_items": null, "description": "User-facing application name."},
        {"name": "minimum_version", "type": "ProtocolVersion", "required": true, "many": false, "max_items": null, "description": "Oldest protocol accepted by the client."},
        {"name": "maximum_version", "type": "ProtocolVersion", "required": true, "many": false, "max_items": null, "description": "Newest protocol accepted by the client."},
        {"name": "required_features", "type": "ProtocolFeatureId", "required": true, "many": true, "max_items": 64, "description": "Features without which this client cannot operate."},
        {"name": "optional_features", "type": "ProtocolFeatureId", "required": true, "many": true, "max_items": 64, "description": "Features the client can use when available."}
      ]
    },
    {
      "name": "ServerHello",
      "description": "Negotiated protocol version and bridge feature set.",
      "fields": [
        {"name": "selected_version", "type": "ProtocolVersion", "required": true, "many": false, "max_items": null, "description": "Mutually supported protocol version."},
        {"name": "server_instance_id", "type": "ServerInstanceId", "required": true, "many": false, "max_items": null, "description": "Changes whenever the bridge process identity changes."},
        {"name": "protocol_session_id", "type": "ProtocolSessionId", "required": true, "many": false, "max_items": null, "description": "Server-issued connection ownership identity."},
        {"name": "negotiation_token", "type": "NegotiationToken", "required": true, "many": false, "max_items": null, "description": "Binds subsequent requests to this negotiated selection."},
        {"name": "bridge_version", "type": "ComponentVersion", "required": true, "many": false, "max_items": null, "description": "Bridge component version."},
        {"name": "enabled_features", "type": "ProtocolFeatureId", "required": true, "many": true, "max_items": 64, "description": "Protocol features enabled for this connection."},
        {"name": "event_buffer_capacity", "type": "QueueCapacity", "required": true, "many": false, "max_items": null, "description": "Maximum retained event count."}
      ]
    },
    {
      "name": "ResourceKey",
      "description": "One device-scoped writable resource.",
      "fields": [
        {"name": "receiver_id", "type": "ReceiverId", "required": true, "many": false, "max_items": null, "description": "Receiver that owns the route."},
        {"name": "generation_id", "type": "GenerationId", "required": true, "many": false, "max_items": null, "description": "Receiver generation to which ownership is bound."},
        {"name": "device_id", "type": "LogicalDeviceId", "required": true, "many": false, "max_items": null, "description": "Logical resource owner."},
        {"name": "kind", "type": "ResourceKind", "required": true, "many": false, "max_items": null, "description": "Generic resource domain."}
      ]
    },
    {
      "name": "LeaseRequest",
      "description": "Atomic request for one or more writable resources.",
      "fields": [
        {"name": "request_id", "type": "RequestId", "required": true, "many": false, "max_items": null, "description": "Idempotency identity."},
        {"name": "client_id", "type": "ClientId", "required": true, "many": false, "max_items": null, "description": "Requesting client."},
        {"name": "resources", "type": "ResourceKey", "required": true, "many": true, "max_items": 32, "description": "Complete atomic resource set."},
        {"name": "duration_ms", "type": "LeaseDurationMs", "required": true, "many": false, "max_items": null, "description": "Renewable lease duration."}
      ]
    },
    {
      "name": "LeaseGrant",
      "description": "Granted ownership lease.",
      "fields": [
        {"name": "lease_id", "type": "LeaseId", "required": true, "many": false, "max_items": null, "description": "Lease identity."},
        {"name": "client_id", "type": "ClientId", "required": true, "many": false, "max_items": null, "description": "Owning client."},
        {"name": "resources", "type": "ResourceKey", "required": true, "many": true, "max_items": 32, "description": "Atomically owned resources."},
        {"name": "expires_at_ms", "type": "MonotonicMs", "required": true, "many": false, "max_items": null, "description": "Exclusive monotonic expiry."},
        {"name": "state", "type": "LeaseState", "required": true, "many": false, "max_items": null, "description": "Current lease state."}
      ]
    },
    {
      "name": "LeaseConflict",
      "description": "Deterministic first conflict from an otherwise atomic lease request.",
      "fields": [
        {"name": "conflicting_client", "type": "ClientId", "required": true, "many": false, "max_items": null, "description": "Current owner."},
        {"name": "conflicting_resource", "type": "ResourceKey", "required": true, "many": false, "max_items": null, "description": "First conflict in canonical resource order."}
      ]
    },
    {
      "name": "LeaseRejection",
      "description": "Structured lease rejection unrelated to another owner.",
      "fields": [
        {"name": "error_kind", "type": "ProtocolErrorKind", "required": true, "many": false, "max_items": null, "description": "Stable rejection category."},
        {"name": "finding_id", "type": "FindingId", "required": true, "many": false, "max_items": null, "description": "Central error catalog reference."}
      ]
    },
    {
      "name": "RenewLeaseRequest",
      "description": "Idempotent renewal of one existing lease.",
      "fields": [
        {"name": "request_id", "type": "RequestId", "required": true, "many": false, "max_items": null, "description": "Idempotency identity."},
        {"name": "client_id", "type": "ClientId", "required": true, "many": false, "max_items": null, "description": "Owning client."},
        {"name": "lease_id", "type": "LeaseId", "required": true, "many": false, "max_items": null, "description": "Lease to renew."},
        {"name": "duration_ms", "type": "LeaseDurationMs", "required": true, "many": false, "max_items": null, "description": "New bounded duration."}
      ]
    },
    {
      "name": "ReleaseLeaseRequest",
      "description": "Idempotent release of one existing lease.",
      "fields": [
        {"name": "request_id", "type": "RequestId", "required": true, "many": false, "max_items": null, "description": "Idempotency identity."},
        {"name": "client_id", "type": "ClientId", "required": true, "many": false, "max_items": null, "description": "Owning client."},
        {"name": "lease_id", "type": "LeaseId", "required": true, "many": false, "max_items": null, "description": "Lease to release."}
      ]
    },
    {
      "name": "EventCursor",
      "description": "Complete resumable position in one event stream projection.",
      "fields": [
        {"name": "stream_id", "type": "StreamId", "required": true, "many": false, "max_items": null, "description": "Bridge event-stream identity."},
        {"name": "stream_epoch", "type": "StreamEpoch", "required": true, "many": false, "max_items": null, "description": "Changes whenever the event stream restarts."},
        {"name": "projection_revision", "type": "ProjectionRevision", "required": true, "many": false, "max_items": null, "description": "Snapshot and event projection contract revision."},
        {"name": "sequence", "type": "SequenceNumber", "required": true, "many": false, "max_items": null, "description": "Last event reflected by this cursor."}
      ]
    },
    {
      "name": "EndpointSnapshot",
      "description": "Independent route, power, sleep, activity, contact, and freshness facts.",
      "fields": [
        {"name": "endpoint_id", "type": "EndpointId", "required": true, "many": false, "max_items": null, "description": "Stable logical route identity."},
        {"name": "route_kind", "type": "RouteKind", "required": true, "many": false, "max_items": null, "description": "Transport route category."},
        {"name": "route_state", "type": "RouteState", "required": true, "many": false, "max_items": null, "description": "Current route evidence."},
        {"name": "connection_mode", "type": "ConnectionMode", "required": true, "many": false, "max_items": null, "description": "User-facing connection mode."},
        {"name": "power_state", "type": "PowerState", "required": true, "many": false, "max_items": null, "description": "Explicit power evidence, independent of route."},
        {"name": "sleep_state", "type": "SleepState", "required": true, "many": false, "max_items": null, "description": "Explicit sleep evidence."},
        {"name": "activity_state", "type": "ActivityState", "required": true, "many": false, "max_items": null, "description": "Recent activity evidence."},
        {"name": "contact_state", "type": "ContactState", "required": true, "many": false, "max_items": null, "description": "Mat-contact evidence where applicable."},
        {"name": "freshness", "type": "FreshnessState", "required": true, "many": false, "max_items": null, "description": "Freshness of the route projection."},
        {"name": "confidence", "type": "EvidenceConfidence", "required": true, "many": false, "max_items": null, "description": "How directly the state was established."},
        {"name": "evidence_claim_id", "type": "EvidenceClaimId", "required": false, "many": false, "max_items": null, "description": "Privacy-safe evidence provenance when available."},
        {"name": "observed_at_ms", "type": "MonotonicMs", "required": false, "many": false, "max_items": null, "description": "Bridge-local observation instant."}
      ]
    },
    {
      "name": "BatteryObservation",
      "description": "Battery availability and value without collapsing unknown and unavailable.",
      "fields": [
        {"name": "availability", "type": "TelemetryAvailability", "required": true, "many": false, "max_items": null, "description": "Whether a current value exists."},
        {"name": "percentage", "type": "BatteryPercent", "required": false, "many": false, "max_items": null, "description": "Reported value only when availability is reported."},
        {"name": "freshness", "type": "FreshnessState", "required": true, "many": false, "max_items": null, "description": "Freshness of the battery observation."},
        {"name": "confidence", "type": "EvidenceConfidence", "required": true, "many": false, "max_items": null, "description": "How directly the value was established."},
        {"name": "observed_at_ms", "type": "MonotonicMs", "required": false, "many": false, "max_items": null, "description": "Bridge-local observation instant."}
      ]
    },
    {
      "name": "ResourceOwnershipSnapshot",
      "description": "Current bounded application ownership for one generation-scoped resource.",
      "fields": [
        {"name": "resource", "type": "ResourceKey", "required": true, "many": false, "max_items": null, "description": "Owned resource."},
        {"name": "client_id", "type": "ClientId", "required": true, "many": false, "max_items": null, "description": "Current owning client."},
        {"name": "lease_id", "type": "LeaseId", "required": true, "many": false, "max_items": null, "description": "Authorizing lease."},
        {"name": "expires_at_ms", "type": "MonotonicMs", "required": true, "many": false, "max_items": null, "description": "Exclusive bridge-clock expiry."}
      ]
    },
    {
      "name": "LogicalDeviceSnapshot",
      "description": "Application-neutral logical controller state.",
      "fields": [
        {"name": "device_id", "type": "LogicalDeviceId", "required": true, "many": false, "max_items": null, "description": "Logical identity."},
        {"name": "device_kind", "type": "DeviceKind", "required": true, "many": false, "max_items": null, "description": "Device category."},
        {"name": "product_id", "type": "ProductId", "required": true, "many": false, "max_items": null, "description": "Observed product id."},
        {"name": "profile_id", "type": "ProfileId", "required": false, "many": false, "max_items": null, "description": "Qualified profile when available."},
        {"name": "pairing", "type": "PairingState", "required": true, "many": false, "max_items": null, "description": "Receiver inventory state independent of route."},
        {"name": "presence", "type": "PresenceState", "required": true, "many": false, "max_items": null, "description": "Derived controller presence."},
        {"name": "support_level", "type": "SupportLevel", "required": true, "many": false, "max_items": null, "description": "Evidence-backed support level."},
        {"name": "endpoints", "type": "EndpointSnapshot", "required": true, "many": true, "max_items": 8, "description": "Independent known routes in canonical endpoint order."},
        {"name": "battery", "type": "BatteryObservation", "required": true, "many": false, "max_items": null, "description": "Current battery projection."},
        {"name": "capabilities", "type": "CapabilityId", "required": true, "many": true, "max_items": 128, "description": "Qualified semantic capabilities."}
      ]
    },
    {
      "name": "ReceiverSnapshot",
      "description": "Generation-bound receiver and child inventory.",
      "fields": [
        {"name": "receiver_id", "type": "ReceiverId", "required": true, "many": false, "max_items": null, "description": "Logical receiver identity."},
        {"name": "generation_id", "type": "GenerationId", "required": true, "many": false, "max_items": null, "description": "Current receiver generation."},
        {"name": "lifecycle", "type": "ReceiverLifecycleState", "required": true, "many": false, "max_items": null, "description": "Receiver lifecycle state."},
        {"name": "devices", "type": "LogicalDeviceSnapshot", "required": true, "many": true, "max_items": 32, "description": "Independent logical children."},
        {"name": "ownership", "type": "ResourceOwnershipSnapshot", "required": true, "many": true, "max_items": 96, "description": "Current generation-scoped write ownership."},
        {"name": "stable_restore_enabled", "type": "Boolean", "required": true, "many": false, "max_items": null, "description": "Whether stable state restoration is enabled."},
        {"name": "restore_state", "type": "RestoreState", "required": true, "many": false, "max_items": null, "description": "Current restoration state."}
      ]
    },
    {
      "name": "BridgeSnapshot",
      "description": "Sequence-bound complete bridge snapshot.",
      "fields": [
        {"name": "cursor", "type": "EventCursor", "required": true, "many": false, "max_items": null, "description": "Complete event position reflected by this snapshot."},
        {"name": "receivers", "type": "ReceiverSnapshot", "required": true, "many": true, "max_items": 16, "description": "Exactly one current generation per receiver in canonical order."}
      ]
    },
    {
      "name": "LightingFrame",
      "description": "One logical-device direct-mode frame.",
      "fields": [
        {"name": "device_id", "type": "LogicalDeviceId", "required": true, "many": false, "max_items": null, "description": "Frame target."},
        {"name": "frame_index", "type": "FrameIndex", "required": true, "many": false, "max_items": null, "description": "Transaction-local frame order."},
        {"name": "colors", "type": "RgbColor", "required": true, "many": true, "max_items": 4096, "description": "Logical LED colors before carrier translation."}
      ]
    },
    {
      "name": "DeviceProfileBinding",
      "description": "Exact profile and lighting dimensions bound to one transaction target.",
      "fields": [
        {"name": "device_id", "type": "LogicalDeviceId", "required": true, "many": false, "max_items": null, "description": "Logical transaction target."},
        {"name": "profile_id", "type": "ProfileId", "required": true, "many": false, "max_items": null, "description": "Qualified child profile selected at admission."},
        {"name": "profile_digest", "type": "ProfileDigest", "required": true, "many": false, "max_items": null, "description": "Immutable profile-catalog digest selected at admission."},
        {"name": "application_slot_count", "type": "LedCount", "required": true, "many": false, "max_items": null, "description": "Exact logical color count required by this profile."}
      ]
    },
    {
      "name": "TransactionRequest",
      "description": "Atomic generation- and ownership-bound operation.",
      "fields": [
        {"name": "request_id", "type": "RequestId", "required": true, "many": false, "max_items": null, "description": "Idempotency identity."},
        {"name": "transaction_id", "type": "TransactionId", "required": true, "many": false, "max_items": null, "description": "Transaction identity."},
        {"name": "client_id", "type": "ClientId", "required": true, "many": false, "max_items": null, "description": "Submitting client."},
        {"name": "lease_id", "type": "LeaseId", "required": true, "many": false, "max_items": null, "description": "Atomic ownership proof."},
        {"name": "receiver_id", "type": "ReceiverId", "required": true, "many": false, "max_items": null, "description": "Receiver target."},
        {"name": "generation_id", "type": "GenerationId", "required": true, "many": false, "max_items": null, "description": "Generation binding."},
        {"name": "receiver_profile_id", "type": "ProfileId", "required": true, "many": false, "max_items": null, "description": "Exact qualified receiver profile selected at admission."},
        {"name": "receiver_profile_digest", "type": "ProfileDigest", "required": true, "many": false, "max_items": null, "description": "Immutable receiver profile-catalog digest selected at admission."},
        {"name": "device_profiles", "type": "DeviceProfileBinding", "required": true, "many": true, "max_items": 32, "description": "Complete canonical profile binding for every frame target."},
        {"name": "transaction_class", "type": "TransactionClass", "required": true, "many": false, "max_items": null, "description": "Ordering and coalescing class."},
        {"name": "deadline_ms", "type": "MonotonicMs", "required": true, "many": false, "max_items": null, "description": "Absolute monotonic deadline."},
        {"name": "resources", "type": "ResourceKey", "required": true, "many": true, "max_items": 32, "description": "Complete ownership set."},
        {"name": "frames", "type": "LightingFrame", "required": true, "many": true, "max_items": 32, "description": "Complete atomic frame batch."}
      ]
    },
    {
      "name": "TransactionProgress",
      "description": "Nonterminal generation-bound transaction projection.",
      "fields": [
        {"name": "request_id", "type": "RequestId", "required": true, "many": false, "max_items": null, "description": "Original idempotency identity."},
        {"name": "request_digest", "type": "RequestDigest", "required": true, "many": false, "max_items": null, "description": "Canonical request digest used for exact replay."},
        {"name": "transaction_id", "type": "TransactionId", "required": true, "many": false, "max_items": null, "description": "Transaction identity."},
        {"name": "receiver_id", "type": "ReceiverId", "required": true, "many": false, "max_items": null, "description": "Bound receiver."},
        {"name": "generation_id", "type": "GenerationId", "required": true, "many": false, "max_items": null, "description": "Bound receiver generation."},
        {"name": "state", "type": "TransactionState", "required": true, "many": false, "max_items": null, "description": "Current nonterminal state."},
        {"name": "admission", "type": "QueueAdmission", "required": true, "many": false, "max_items": null, "description": "Bounded queue decision."},
        {"name": "declared_frames", "type": "FrameCount", "required": true, "many": false, "max_items": null, "description": "Frames promised by the transaction."},
        {"name": "delivered_frames", "type": "DeliveredFrameCount", "required": true, "many": false, "max_items": null, "description": "Frames terminally accepted so far."},
        {"name": "side_effect_certainty", "type": "SideEffectCertainty", "required": true, "many": false, "max_items": null, "description": "Current transport side-effect knowledge."},
        {"name": "live_write_executed", "type": "Boolean", "required": true, "many": false, "max_items": null, "description": "Whether transport has begun a hardware write."}
      ]
    },
    {
      "name": "TransactionTerminal",
      "description": "Immutable terminal transaction outcome retained for bounded lookup.",
      "fields": [
        {"name": "request_id", "type": "RequestId", "required": true, "many": false, "max_items": null, "description": "Original idempotency identity."},
        {"name": "request_digest", "type": "RequestDigest", "required": true, "many": false, "max_items": null, "description": "Canonical request digest used for exact replay."},
        {"name": "transaction_id", "type": "TransactionId", "required": true, "many": false, "max_items": null, "description": "Transaction identity."},
        {"name": "receiver_id", "type": "ReceiverId", "required": true, "many": false, "max_items": null, "description": "Bound receiver."},
        {"name": "generation_id", "type": "GenerationId", "required": true, "many": false, "max_items": null, "description": "Bound receiver generation."},
        {"name": "state", "type": "TransactionState", "required": true, "many": false, "max_items": null, "description": "Terminal succeeded, failed, revoked, or superseded state."},
        {"name": "declared_frames", "type": "FrameCount", "required": true, "many": false, "max_items": null, "description": "Frames promised by the transaction."},
        {"name": "delivered_frames", "type": "DeliveredFrameCount", "required": true, "many": false, "max_items": null, "description": "Frames terminally accepted by transport."},
        {"name": "side_effect_certainty", "type": "SideEffectCertainty", "required": true, "many": false, "max_items": null, "description": "Terminal transport side-effect knowledge."},
        {"name": "live_write_executed", "type": "Boolean", "required": true, "many": false, "max_items": null, "description": "Whether transport began a hardware write."},
        {"name": "automatic_retry", "type": "Boolean", "required": true, "many": false, "max_items": null, "description": "Whether exact automatic replay is safe; false after possible transport."},
        {"name": "device_application", "type": "DeviceApplicationState", "required": true, "many": false, "max_items": null, "description": "Separate child-application evidence."},
        {"name": "terminal_sequence", "type": "SequenceNumber", "required": true, "many": false, "max_items": null, "description": "Immutable completion event sequence."},
        {"name": "error_kind", "type": "ProtocolErrorKind", "required": false, "many": false, "max_items": null, "description": "Structured failure category."},
        {"name": "superseded_by", "type": "TransactionId", "required": false, "many": false, "max_items": null, "description": "Newer unsent effect transaction that replaced this one."}
      ]
    },
    {
      "name": "TransactionUnavailable",
      "description": "Outcome lookup cannot return a retained transaction record.",
      "fields": [
        {"name": "transaction_id", "type": "TransactionId", "required": true, "many": false, "max_items": null, "description": "Requested transaction identity."},
        {"name": "error_kind", "type": "ProtocolErrorKind", "required": true, "many": false, "max_items": null, "description": "Unknown or evicted outcome category."},
        {"name": "finding_id", "type": "FindingId", "required": true, "many": false, "max_items": null, "description": "Central error catalog reference."}
      ]
    },
    {
      "name": "TransactionLookup",
      "description": "Idempotent lookup of one previously submitted transaction.",
      "fields": [
        {"name": "request_id", "type": "RequestId", "required": true, "many": false, "max_items": null, "description": "Lookup request identity."},
        {"name": "client_id", "type": "ClientId", "required": true, "many": false, "max_items": null, "description": "Original transaction owner."},
        {"name": "transaction_id", "type": "TransactionId", "required": true, "many": false, "max_items": null, "description": "Transaction to inspect."}
      ]
    },
    {
      "name": "SubscriptionRequest",
      "description": "Bounded event subscription cursor.",
      "fields": [
        {"name": "client_id", "type": "ClientId", "required": true, "many": false, "max_items": null, "description": "Subscribing client."},
        {"name": "subscription_id", "type": "SubscriptionId", "required": false, "many": false, "max_items": null, "description": "Server-issued subscription identity when continuing."},
        {"name": "expected_cursor", "type": "EventCursor", "required": false, "many": false, "max_items": null, "description": "Previously observed complete event cursor."},
        {"name": "max_events", "type": "EventBatchLimit", "required": true, "many": false, "max_items": null, "description": "Maximum events requested in this batch."}
      ]
    },
    {
      "name": "BridgeEvent",
      "description": "Sequence-bound typed event with snapshot references.",
      "fields": [
        {"name": "sequence", "type": "SequenceNumber", "required": true, "many": false, "max_items": null, "description": "Strictly increasing sequence."},
        {"name": "kind", "type": "EventKind", "required": true, "many": false, "max_items": null, "description": "Typed event category."},
        {"name": "receiver_id", "type": "ReceiverId", "required": false, "many": false, "max_items": null, "description": "Affected receiver when applicable."},
        {"name": "generation_id", "type": "GenerationId", "required": false, "many": false, "max_items": null, "description": "Affected generation when applicable."},
