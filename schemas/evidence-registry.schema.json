{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hyperflux.dev/schemas/evidence-registry-v1.json",
  "title": "HyperFlux evidence claim registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "claims"],
  "properties": {
    "$schema": {"type": "string"},
    "schema": {"const": "hyperflux-evidence-registry-v1"},
    "claims": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "summary", "evidence_level", "privacy", "profile_ids", "qualifies_capabilities", "source_refs", "limitations"],
        "properties": {
          "id": {"type": "string", "pattern": "^claim\\.[a-z0-9.-]+$"},
          "summary": {"type": "string", "minLength": 1},
          "evidence_level": {"enum": ["requirement", "source-reviewed", "simulation-proven", "hardware-observed", "hardware-qualified", "production-qualified"]},
          "privacy": {"enum": ["public", "public-summary", "sensitive", "private", "forbidden"]},
          "profile_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
          "qualifies_capabilities": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
          "source_refs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["source_id", "paths"],
              "properties": {
                "source_id": {"type": "string"},
                "paths": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}}
              }
            }
          },
          "limitations": {"type": "array", "items": {"type": "string", "minLength": 1}}
        }
      }
    }
  }
}
