{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hyperflux.dev/schemas/compiled-device-knowledge-v1.json",
  "title": "Compiled provenance-bound device knowledge",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schema",
    "source_sha256",
    "candidate_snapshot_id",
    "candidate_snapshot_history",
    "policy",
    "upstreams",
    "reviewed_on",
    "reviewed_sources",
    "candidates"
  ],
  "properties": {
    "$schema": {"const": "../../schemas/compiled-device-knowledge.schema.json"},
    "schema": {"const": "hyperflux-compiled-device-knowledge-v1"},
    "source_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "candidate_snapshot_id": {"type": "string", "pattern": "^catalog\\.[a-z0-9.-]+$"},
    "candidate_snapshot_history": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["snapshot_id", "retrieved_utc", "supersedes_snapshot_id", "candidate_count"],
        "properties": {
          "snapshot_id": {"type": "string"},
          "retrieved_utc": {"type": "string", "format": "date"},
          "supersedes_snapshot_id": {"type": ["string", "null"]},
          "candidate_count": {"type": "integer", "minimum": 0, "maximum": 512}
        }
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_knowledge_grants_transport_authority",
        "reviewed_candidate_links_required",
        "unmapped_selected_methods_allowed",
        "controls_require_qualified_hyperflux_capabilities",
        "source_conflicts_are_not_promoted"
      ],
      "properties": {
        "source_knowledge_grants_transport_authority": {"const": false},
        "reviewed_candidate_links_required": {"const": true},
        "unmapped_selected_methods_allowed": {"const": false},
        "controls_require_qualified_hyperflux_capabilities": {"const": true},
        "source_conflicts_are_not_promoted": {"const": true}
      }
    },
    "upstreams": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": {"type": "object"}
    },
    "reviewed_on": {"type": "string", "format": "date"},
    "reviewed_sources": {
      "type": "array",
      "minItems": 1,
      "maxItems": 128,
      "items": {"type": "object"}
    },
    "candidates": {
      "type": "array",
      "minItems": 1,
      "maxItems": 128,
      "items": {"$ref": "#/$defs/candidate"}
    }
  },
  "$defs": {
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "candidate_id",
        "official_name",
        "device_kind",
        "knowledge_status",
        "sources_present",
        "source_records",
        "source_conflicts",
        "hyperflux_support",
        "hyperflux_profile_ids",
        "qualified_hyperflux_capabilities",
        "settings",
        "reviewed_on",
        "reviewed_source_ids",
        "reviewed_facts",
        "knowledge_gaps",
        "transport_matrix",
        "coverage",
        "notes"
      ],
      "properties": {
        "candidate_id": {"type": "string", "pattern": "^[a-z][a-z0-9-]+$"},
        "official_name": {"type": "string", "minLength": 1, "maxLength": 160},
        "device_kind": {"enum": ["keyboard", "mouse"]},
        "knowledge_status": {"enum": ["conflicted", "cross-referenced", "single-source", "missing"]},
        "sources_present": {"type": "array", "uniqueItems": true, "items": {"enum": ["openrazer", "openrgb"]}},
        "source_records": {"type": "array", "maxItems": 32, "items": {"type": "object"}},
        "source_conflicts": {"type": "array", "maxItems": 32, "items": {"type": "object"}},
        "hyperflux_support": {"enum": ["candidate-only", "route-qualified"]},
        "hyperflux_profile_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
        "qualified_hyperflux_capabilities": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
        "settings": {"type": "array", "maxItems": 256, "items": {"type": "object"}},
        "reviewed_on": {"type": "string", "format": "date"},
        "reviewed_source_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
        "reviewed_facts": {"type": "array", "minItems": 1, "maxItems": 256, "items": {"type": "object"}},
        "knowledge_gaps": {"type": "array", "maxItems": 64, "items": {"type": "object"}},
        "transport_matrix": {"type": "array", "minItems": 4, "maxItems": 4, "items": {"type": "object"}},
        "coverage": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "reviewed_fact_count",
            "reviewed_source_count",
            "official_source_count",
            "upstream_report_count",
            "implementation_record_count",
            "implemented_fact_count",
            "physically_qualified_fact_count",
            "open_gap_count"
          ],
          "properties": {
            "reviewed_fact_count": {"type": "integer", "minimum": 0},
            "reviewed_source_count": {"type": "integer", "minimum": 0},
            "official_source_count": {"type": "integer", "minimum": 0},
            "upstream_report_count": {"type": "integer", "minimum": 0},
            "implementation_record_count": {"type": "integer", "minimum": 0},
            "implemented_fact_count": {"type": "integer", "minimum": 0},
            "physically_qualified_fact_count": {"type": "integer", "minimum": 0},
            "open_gap_count": {"type": "integer", "minimum": 0}
          }
        },
        "notes": {"type": "array", "maxItems": 16, "items": {"type": "string"}}
      }
    }
  }
}
