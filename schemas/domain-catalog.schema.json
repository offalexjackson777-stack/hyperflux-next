{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hyperflux.dev/schemas/domain-catalog-v1.json",
  "title": "HyperFlux domain type catalog",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "numeric_types", "string_types", "enums"],
  "properties": {
    "$schema": {"type": "string"},
    "schema": {"const": "hyperflux-domain-catalog-v1"},
    "numeric_types": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "wire", "rust", "cpp", "python_min", "minimum", "maximum"],
        "properties": {
          "name": {"type": "string", "pattern": "^[A-Z][A-Za-z0-9]+$"},
          "wire": {"type": "string", "pattern": "^[a-z][a-z0-9_]+$"},
          "rust": {"enum": ["u8", "u16", "u32", "u64"]},
          "cpp": {"enum": ["std::uint8_t", "std::uint16_t", "std::uint32_t", "std::uint64_t"]},
          "python_min": {"type": "integer", "minimum": 0},
          "minimum": {"type": "integer", "minimum": 0},
          "maximum": {"type": "integer", "minimum": 0}
        }
      }
    },
    "string_types": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "wire", "minimum_length", "maximum_length"],
        "properties": {
          "name": {"type": "string", "pattern": "^[A-Z][A-Za-z0-9]+$"},
          "wire": {"type": "string", "pattern": "^[a-z][a-z0-9_]+$"},
          "minimum_length": {"type": "integer", "minimum": 1},
          "maximum_length": {"type": "integer", "minimum": 1}
        }
      }
    },
    "enums": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "values"],
        "properties": {
          "name": {"type": "string", "pattern": "^[A-Z][A-Za-z0-9]+$"},
          "values": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {"type": "string", "pattern": "^[a-z][a-z0-9.-]*$"}
          }
        }
      }
    }
  }
}

