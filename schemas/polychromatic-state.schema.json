{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hyperflux.dev/schemas/polychromatic-state-v1.json",
  "title": "HyperFlux Polychromatic stable lighting state",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "devices"],
  "properties": {
    "schema": {"const": "hyperflux-polychromatic-state-v1"},
    "devices": {
      "type": "object",
      "maxProperties": 64,
      "propertyNames": {"pattern": "^hfx-[0-9a-f]{24}$"},
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["mode", "brightness", "colors"],
        "properties": {
          "mode": {"enum": ["unknown", "static", "off"]},
          "brightness": {"type": "integer", "minimum": 0, "maximum": 100},
          "colors": {
            "type": "array",
            "minItems": 1,
            "maxItems": 1024,
            "items": {"type": "string", "pattern": "^[0-9a-f]{6}$"}
          }
        }
      }
    }
  }
}
