{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hyperflux.dev/schemas/reviewed-device-facts-v1.json",
  "title": "Reviewed product documentation and protocol research",
  "type": "object",
  "additionalProperties": false,
  "required": ["$schema", "schema", "reviewed_on", "sources", "candidates"],
  "properties": {
    "$schema": {"type": "string"},
    "schema": {"const": "hyperflux-reviewed-device-facts-v1"},
    "reviewed_on": {"type": "string", "format": "date"},
    "sources": {
      "type": "array",
      "minItems": 1,
      "maxItems": 128,
      "items": {"$ref": "#/$defs/source"}
    },
    "candidates": {
      "type": "array",
      "minItems": 1,
      "maxItems": 128,
      "items": {"$ref": "#/$defs/candidate"}
    }
  },
  "$defs": {
    "sourceId": {"type": "string", "pattern": "^[a-z][a-z0-9.-]+$"},
    "route": {
      "enum": [
        "bluetooth",
        "hyperflux-receiver",
        "not-route-specific",
        "vendor-wireless-receiver",
        "wired"
      ]
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind",
        "publisher",
        "title",
        "url",
        "retrieved_on",
        "revision",
        "authority"
      ],
      "properties": {
        "id": {"$ref": "#/$defs/sourceId"},
        "kind": {
          "enum": [
            "official-compatibility",
            "official-manual",
            "official-product",
            "official-support",
            "upstream-issue"
          ]
        },
        "publisher": {"type": "string", "minLength": 1, "maxLength": 64},
        "title": {"type": "string", "minLength": 1, "maxLength": 160},
        "url": {"type": "string", "pattern": "^https://"},
        "retrieved_on": {"type": "string", "format": "date"},
        "revision": {"type": "string", "minLength": 1, "maxLength": 160},
        "authority": {
          "type": "array",
          "minItems": 1,
          "maxItems": 8,
          "uniqueItems": true,
          "items": {
            "enum": [
              "product-capability",
              "product-procedure",
              "transport-identity",
              "transport-limitation"
            ]
          }
        }
      }
    },
    "factValue": {
      "oneOf": [
        {"type": "boolean"},
        {"type": "integer"},
        {"type": "string", "minLength": 1, "maxLength": 320},
        {
          "type": "array",
          "minItems": 1,
          "maxItems": 32,
          "uniqueItems": true,
          "items": {"type": "integer"}
        },
        {
          "type": "array",
          "minItems": 1,
          "maxItems": 32,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1, "maxLength": 96}
        }
      ]
    },
    "fact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "semantic_capability",
        "family",
        "label",
        "value",
        "routes",
        "source_ids",
        "claim_state",
        "notes"
      ],
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z][a-z0-9-]+$"},
        "semantic_capability": {"type": "string", "pattern": "^[a-z][a-z0-9.-]+$"},
        "family": {
          "enum": [
            "connectivity",
            "identity",
            "input",
            "lighting",
            "macros",
            "performance",
            "power",
            "profiles",
            "telemetry"
          ]
        },
        "label": {"type": "string", "minLength": 1, "maxLength": 96},
        "value": {"$ref": "#/$defs/factValue"},
        "unit": {"type": "string", "minLength": 1, "maxLength": 32},
        "routes": {
          "type": "array",
          "minItems": 1,
          "maxItems": 5,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/route"}
        },
        "source_ids": {
          "type": "array",
          "minItems": 1,
          "maxItems": 12,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/sourceId"}
        },
        "claim_state": {"enum": ["documented-product", "reported-upstream"]},
        "notes": {
          "type": "array",
          "maxItems": 8,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1, "maxLength": 320}
        }
      }
    },
    "gap": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "detail", "status", "source_ids"],
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z][a-z0-9-]+$"},
        "title": {"type": "string", "minLength": 1, "maxLength": 120},
        "detail": {"type": "string", "minLength": 1, "maxLength": 480},
        "status": {"enum": ["not-documented", "not-implemented", "not-mapped", "not-validated", "source-conflict"]},
        "source_ids": {
          "type": "array",
          "maxItems": 12,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/sourceId"}
        }
      }
    },
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["candidate_id", "source_ids", "facts", "gaps"],
      "properties": {
        "candidate_id": {"type": "string", "pattern": "^[a-z][a-z0-9-]+$"},
        "source_ids": {
          "type": "array",
          "minItems": 1,
          "maxItems": 16,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/sourceId"}
        },
        "facts": {
          "type": "array",
          "minItems": 1,
          "maxItems": 96,
          "items": {"$ref": "#/$defs/fact"}
        },
        "gaps": {
          "type": "array",
          "maxItems": 32,
          "items": {"$ref": "#/$defs/gap"}
        }
      }
    }
  }
}
