{
  "$schema": "domain-catalog.schema.json",
  "schema": "hyperflux-domain-catalog-v1",
  "numeric_types": [
    {"name": "GenerationId", "wire": "generation_id", "rust": "u64", "cpp": "std::uint64_t", "python_min": 1, "minimum": 1, "maximum": 18446744073709551615},
    {"name": "VendorId", "wire": "vendor_id", "rust": "u16", "cpp": "std::uint16_t", "python_min": 0, "minimum": 0, "maximum": 65535},
    {"name": "ProductId", "wire": "product_id", "rust": "u16", "cpp": "std::uint16_t", "python_min": 0, "minimum": 0, "maximum": 65535},
    {"name": "ProfileRevision", "wire": "profile_revision", "rust": "u32", "cpp": "std::uint32_t", "python_min": 1, "minimum": 1, "maximum": 4294967295},
    {"name": "BatteryPercent", "wire": "battery_percent", "rust": "u8", "cpp": "std::uint8_t", "python_min": 0, "minimum": 0, "maximum": 100},
    {"name": "Brightness", "wire": "brightness", "rust": "u8", "cpp": "std::uint8_t", "python_min": 0, "minimum": 0, "maximum": 255},
    {"name": "DurationMs", "wire": "duration_ms", "rust": "u64", "cpp": "std::uint64_t", "python_min": 0, "minimum": 0, "maximum": 86400000},
    {"name": "SequenceNumber", "wire": "sequence_number", "rust": "u64", "cpp": "std::uint64_t", "python_min": 0, "minimum": 0, "maximum": 18446744073709551615},
    {"name": "LedIndex", "wire": "led_index", "rust": "u16", "cpp": "std::uint16_t", "python_min": 0, "minimum": 0, "maximum": 4095},
    {"name": "LedCount", "wire": "led_count", "rust": "u16", "cpp": "std::uint16_t", "python_min": 0, "minimum": 0, "maximum": 4096},
    {"name": "CarrierIndex", "wire": "carrier_index", "rust": "u16", "cpp": "std::uint16_t", "python_min": 0, "minimum": 0, "maximum": 4095}
  ],
  "string_types": [
    {"name": "ReceiverId", "wire": "receiver_id", "minimum_length": 1, "maximum_length": 128},
    {"name": "LogicalDeviceId", "wire": "logical_device_id", "minimum_length": 1, "maximum_length": 128},
    {"name": "EndpointId", "wire": "endpoint_id", "minimum_length": 1, "maximum_length": 128},
    {"name": "LeaseId", "wire": "lease_id", "minimum_length": 1, "maximum_length": 128},
    {"name": "TransactionId", "wire": "transaction_id", "minimum_length": 1, "maximum_length": 128},
    {"name": "ProfileId", "wire": "profile_id", "minimum_length": 1, "maximum_length": 128},
    {"name": "CapabilityId", "wire": "capability_id", "minimum_length": 1, "maximum_length": 128},
    {"name": "EvidenceClaimId", "wire": "evidence_claim_id", "minimum_length": 1, "maximum_length": 160},
    {"name": "ScenarioId", "wire": "scenario_id", "minimum_length": 1, "maximum_length": 128},
    {"name": "RestoreId", "wire": "restore_id", "minimum_length": 1, "maximum_length": 128}
  ],
  "enums": [
    {"name": "DeviceKind", "values": ["receiver", "mat", "mouse", "keyboard", "unknown"]},
    {"name": "ProfileKind", "values": ["receiver", "child", "surface"]},
    {"name": "RouteKind", "values": ["hyperflux-wireless", "direct-usb", "bluetooth"]},
    {"name": "PairingState", "values": ["paired", "unpaired", "unknown"]},
    {"name": "PresenceState", "values": ["available", "sleeping", "unavailable", "unknown"]},
    {"name": "ConnectionMode", "values": ["hyperflux-2.4ghz", "direct-usb", "bluetooth", "unknown"]},
    {"name": "RouteState", "values": ["available", "unavailable", "stale", "unknown"]},
    {"name": "PowerState", "values": ["on", "off", "unknown"]},
    {"name": "SleepState", "values": ["awake", "asleep", "unknown"]},
    {"name": "ContactState", "values": ["on-mat", "off-mat", "unknown", "not-applicable"]},
    {"name": "ActivityState", "values": ["active", "idle", "unknown"]},
    {"name": "FreshnessState", "values": ["fresh", "stale", "unknown"]},
    {"name": "ReceiverLifecycleState", "values": ["active", "suspended", "partially-suspended", "disconnecting", "unknown"]},
    {"name": "FixtureSource", "values": ["deterministic-simulator", "sanitized-replay"]},
    {"name": "TransportOutcome", "values": ["delivered", "failed"]},
    {"name": "ApplyOutcome", "values": ["applied", "ignored-older-observation", "rejected-stale-generation", "rejected-receiver-absent", "rejected-unknown-device", "rejected-unavailable-route", "rejected-unqualified-write", "rejected-invalid-transition", "rejected-transport-failure", "recorded-malformed-observation"]},
    {"name": "EvidenceConfidence", "values": ["observed", "derived", "inferred", "unknown"]},
    {"name": "EvidenceLevel", "values": ["requirement", "source-reviewed", "simulation-proven", "hardware-observed", "hardware-qualified", "production-qualified"]},
    {"name": "PrivacyClass", "values": ["public", "public-summary", "sensitive", "private", "forbidden"]},
    {"name": "SupportLevel", "values": ["candidate", "identified", "read-only", "telemetry-qualified", "lighting-qualified", "settings-qualified", "pairing-qualified", "production-qualified"]},
    {"name": "ReceiverState", "values": ["absent", "discovered-read-only", "observed", "profile-qualified", "session-authorized", "degraded-read-only"]},
    {"name": "TransactionState", "values": ["created", "validated", "ownership-bound", "generation-bound", "queued", "sent", "health-pending", "succeeded", "failed", "revoked"]},
    {"name": "LeaseState", "values": ["requested", "granted", "renewed", "released", "expired", "revoked"]},
    {"name": "ResourceKind", "values": ["mouse-lighting", "keyboard-lighting", "mouse-settings", "keyboard-settings", "receiver-pairing"]},
    {"name": "ErrorSeverity", "values": ["info", "warning", "error", "critical"]}
  ]
}
