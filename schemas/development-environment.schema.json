{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hyperflux.dev/schemas/development-environment-v1.json",
  "title": "HyperFlux reproducible development environment",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schema",
    "platform",
    "base_image",
    "archive",
    "system_packages",
    "rust",
    "workspace",
    "network_policy"
  ],
  "properties": {
    "$schema": {"type": "string"},
    "schema": {"const": "hyperflux-development-environment-v1"},
    "platform": {"const": "linux/amd64"},
    "base_image": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository", "tag", "digest"],
      "properties": {
        "repository": {"const": "docker.io/library/archlinux"},
        "tag": {"const": "base-devel"},
        "digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}
      }
    },
    "archive": {
      "type": "object",
      "additionalProperties": false,
      "required": ["date", "mirror", "download_attempts", "disable_low_speed_timeout"],
      "properties": {
        "date": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"},
        "mirror": {
          "type": "string",
          "pattern": "^https://archive\\.archlinux\\.org/repos/[0-9]{4}/[0-9]{2}/[0-9]{2}/\\$repo/os/\\$arch$"
        },
        "download_attempts": {"type": "integer", "minimum": 1, "maximum": 5},
        "disable_low_speed_timeout": {"type": "boolean"}
      }
    },
    "system_packages": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "version"],
        "properties": {
          "name": {"type": "string", "pattern": "^[a-z0-9][a-z0-9+_.-]{0,63}$"},
          "version": {"type": "string", "minLength": 1, "maxLength": 96}
        }
      }
    },
    "rust": {
      "type": "object",
      "additionalProperties": false,
      "required": ["installer", "toolchain", "profile", "components"],
      "properties": {
        "installer": {"const": "arch-rustup-package"},
        "toolchain": {"type": "string", "minLength": 1, "maxLength": 128},
        "profile": {"const": "minimal"},
        "components": {
          "type": "array",
          "minItems": 2,
          "maxItems": 8,
          "uniqueItems": true,
          "items": {"enum": ["clippy", "rustfmt", "rust-src"]}
        }
      }
    },
    "workspace": {
      "type": "object",
      "additionalProperties": false,
      "required": ["user", "uid", "path"],
      "properties": {
        "user": {"const": "hyperflux"},
        "uid": {"const": 1000},
        "path": {"const": "/workspaces/hyperflux-next"}
      }
    },
    "network_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["container_build", "post_create", "verification"],
      "properties": {
        "container_build": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"enum": ["arch-snapshot-packages", "pinned-rust-toolchain"]}
        },
        "post_create": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"enum": ["pinned-upstream-checkouts", "locked-rust-crates"]}
        },
        "verification": {"const": "forbidden"}
      }
    }
  }
}
