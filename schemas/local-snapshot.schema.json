{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hyperflux.dev/schemas/local-snapshot-v1.json",
  "title": "HyperFlux privacy-safe local device snapshot",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "captured_at", "service", "receivers", "privacy"],
  "properties": {
    "schema": {"const": "hyperflux-local-snapshot-v1"},
    "captured_at": {"type": "string", "format": "date-time"},
    "service": {"enum": ["ready", "starting", "unavailable", "unknown"]},
    "receivers": {
      "type": "array",
      "maxItems": 8,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["generation", "devices"],
        "properties": {
          "generation": {"type": "integer", "minimum": 1},
          "devices": {
            "type": "array",
            "maxItems": 16,
            "items": {"$ref": "#/$defs/device"}
          }
        }
      }
    },
    "privacy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["hardware_serials_included", "stable_host_identifiers_included", "network_upload_performed"],
      "properties": {
        "hardware_serials_included": {"const": false},
        "stable_host_identifiers_included": {"const": false},
        "network_upload_performed": {"const": false}
      }
    }
  },
  "$defs": {
    "device": {
      "type": "object",
      "additionalProperties": false,
      "required": ["slot", "kind", "model", "vendor_id", "product_id", "evidence_state", "evidence_age_ms"],
      "properties": {
        "slot": {"type": "string", "pattern": "^[a-z][a-z0-9-]{0,31}$"},
        "kind": {"enum": ["mouse", "keyboard", "mat", "receiver", "other"]},
        "model": {"type": "string", "minLength": 1, "maxLength": 160},
        "vendor_id": {"type": "integer", "minimum": 0, "maximum": 65535},
        "product_id": {"type": "integer", "minimum": 0, "maximum": 65535},
        "evidence_state": {"enum": ["active", "sleeping", "disconnected", "unknown"]},
        "evidence_age_ms": {"type": ["integer", "null"], "minimum": 0}
      }
    }
  }
}
