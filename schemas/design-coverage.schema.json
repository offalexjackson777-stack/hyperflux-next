{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hyperflux.dev/schemas/design-coverage-v1.json",
  "title": "HyperFlux design-book coverage ledger",
  "type": "object",
  "additionalProperties": false,
  "required": ["$schema", "schema", "entries"],
  "properties": {
    "$schema": {"type": "string"},
    "schema": {"const": "hyperflux-design-coverage-v1"},
    "entries": {
      "type": "array",
      "minItems": 67,
      "maxItems": 67,
      "items": {"$ref": "#/$defs/entry"}
    }
  },
  "$defs": {
    "path": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"
    },
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "section",
        "title",
        "status",
        "owner",
        "evidence",
        "remaining",
        "physical_evidence_required",
        "release_blocking"
      ],
      "properties": {
        "section": {"type": "integer", "minimum": 1, "maximum": 67},
        "title": {"type": "string", "minLength": 1, "maxLength": 120},
        "status": {
          "enum": [
            "software-verified",
            "policy-defined",
            "partially-implemented",
            "blocked-by-physical-evidence",
            "publication-locked"
          ]
        },
        "owner": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64,
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "maxItems": 12,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/path"}
        },
        "remaining": {
          "type": "array",
          "maxItems": 8,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1, "maxLength": 300}
        },
        "physical_evidence_required": {"type": "boolean"},
        "release_blocking": {"type": "boolean"}
      }
    }
  }
}
