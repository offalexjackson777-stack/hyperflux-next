{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hyperflux.dev/schemas/protocol-catalog-v1.json",
  "title": "HyperFlux bridge protocol catalog",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "minimum_version", "maximum_version", "limits", "features", "records", "unions", "methods"],
  "properties": {
    "$schema": {"type": "string"},
    "schema": {"const": "hyperflux-protocol-catalog-v1"},
    "minimum_version": {"type": "integer", "minimum": 1, "maximum": 65535},
    "maximum_version": {"type": "integer", "minimum": 1, "maximum": 65535},
    "limits": {
      "type": "object",
      "additionalProperties": false,
      "required": ["max_message_bytes", "max_json_depth"],
      "properties": {
        "max_message_bytes": {"type": "integer", "minimum": 4096, "maximum": 16777216},
        "max_json_depth": {"const": 128}
      }
    },
    "features": {
      "type": "array",
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/identifier"}
    },
    "records": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/record"}
    },
    "unions": {
      "type": "array",
      "items": {"$ref": "#/$defs/union"}
    },
    "methods": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/method"}
    }
  },
  "$defs": {
    "typeName": {"type": "string", "pattern": "^[A-Z][A-Za-z0-9]+$"},
    "identifier": {"type": "string", "pattern": "^[a-z][a-z0-9.-]*$"},
    "fieldName": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
    "field": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "type", "required", "many", "max_items", "description"],
      "properties": {
        "name": {"$ref": "#/$defs/fieldName"},
        "type": {"$ref": "#/$defs/typeName"},
        "required": {"type": "boolean"},
        "many": {"type": "boolean"},
        "max_items": {"type": ["integer", "null"], "minimum": 1, "maximum": 4096},
        "description": {"type": "string", "minLength": 1, "maxLength": 240}
      }
    },
    "record": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "description", "fields"],
      "properties": {
        "name": {"$ref": "#/$defs/typeName"},
        "description": {"type": "string", "minLength": 1, "maxLength": 240},
        "fields": {"type": "array", "items": {"$ref": "#/$defs/field"}}
      }
    },
    "variant": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "wire", "type", "description"],
      "properties": {
        "name": {"$ref": "#/$defs/typeName"},
        "wire": {"$ref": "#/$defs/identifier"},
        "type": {"$ref": "#/$defs/typeName"},
        "description": {"type": "string", "minLength": 1, "maxLength": 240}
      }
    },
    "union": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "description", "tag", "content", "variants"],
      "properties": {
        "name": {"$ref": "#/$defs/typeName"},
        "description": {"type": "string", "minLength": 1, "maxLength": 240},
        "tag": {"$ref": "#/$defs/fieldName"},
        "content": {"$ref": "#/$defs/fieldName"},
        "variants": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/variant"}}
      }
    },
    "method": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "request", "response", "required_feature", "description"],
      "properties": {
        "name": {"$ref": "#/$defs/identifier"},
        "request": {"$ref": "#/$defs/typeName"},
        "response": {"$ref": "#/$defs/typeName"},
        "required_feature": {"type": ["string", "null"], "pattern": "^[a-z][a-z0-9.-]*$"},
        "description": {"type": "string", "minLength": 1, "maxLength": 240}
      }
    }
  }
}
