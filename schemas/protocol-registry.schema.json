{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hyperflux.dev/schemas/protocol-registry-v1.json",
  "title": "HyperFlux immutable protocol version registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "current_version", "versions"],
  "properties": {
    "$schema": {"type": "string"},
    "schema": {"const": "hyperflux-protocol-registry-v1"},
    "current_version": {"type": "integer", "minimum": 1, "maximum": 65535},
    "versions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["version", "catalog", "sha256"],
        "properties": {
          "version": {"type": "integer", "minimum": 1, "maximum": 65535},
          "catalog": {
            "type": "string",
            "pattern": "^v[1-9][0-9]*/catalog\\.json$",
            "maxLength": 128
          },
          "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
        }
      }
    }
  }
}
