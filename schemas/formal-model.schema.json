{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hyperflux.dev/schemas/formal-model-v1.json",
  "title": "HyperFlux bounded lifecycle model",
  "type": "object",
  "additionalProperties": false,
  "required": ["$schema", "schema", "bounds", "invariants", "required_transitions"],
  "properties": {
    "$schema": {"type": "string"},
    "schema": {"const": "hyperflux-formal-model-v1"},
    "bounds": {
      "type": "object",
      "additionalProperties": false,
      "required": ["maximum_depth", "maximum_states", "receiver_generations"],
      "properties": {
        "maximum_depth": {"type": "integer", "minimum": 1, "maximum": 32},
        "maximum_states": {"type": "integer", "minimum": 1, "maximum": 1000000},
        "receiver_generations": {"const": 2}
      }
    },
    "invariants": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "statement"],
        "properties": {
          "id": {"type": "string", "pattern": "^HFX-MODEL-[0-9]{3}$"},
          "statement": {"type": "string", "minLength": 1, "maxLength": 300}
        }
      }
    },
    "required_transitions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "uniqueItems": true,
      "items": {"type": "string", "pattern": "^[a-z][a-z0-9-]{0,63}$"}
    }
  }
}
