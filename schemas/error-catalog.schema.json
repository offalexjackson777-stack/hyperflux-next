{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hyperflux.dev/schemas/error-catalog-v1.json",
  "title": "HyperFlux central error catalog",
  "type": "object",
  "additionalProperties": false,
  "required": ["$schema", "schema", "remediations", "errors"],
  "properties": {
    "$schema": {"type": "string"},
    "schema": {"const": "hyperflux-error-catalog-v1"},
    "remediations": {
      "type": "array",
      "minItems": 1,
      "maxItems": 128,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/remediation"}
    },
    "errors": {
      "type": "array",
      "minItems": 1,
      "maxItems": 256,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/error"}
    }
  },
  "$defs": {
    "code": {
      "type": "string",
      "pattern": "^HFX-[A-Z]+-[0-9]{3}$"
    },
    "identifier": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$",
      "maxLength": 64
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:-[0-9A-Za-z.-]+)?$",
      "maxLength": 64
    },
    "summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240
    },
    "docsPath": {
      "type": "string",
      "pattern": "^docs/generated/error-catalog\\.md#hfx-[a-z]+-[0-9]{3}$",
      "maxLength": 128
    },
    "remediation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "safe_action", "verification", "automatic"],
      "properties": {
        "id": {"$ref": "#/$defs/identifier"},
        "title": {"type": "string", "minLength": 1, "maxLength": 80},
        "safe_action": {"$ref": "#/$defs/summary"},
        "verification": {"type": "string", "minLength": 1, "maxLength": 160},
        "automatic": {"type": "boolean"}
      }
    },
    "lifecycle": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state", "introduced_in", "deprecated_in", "replacement_code"],
      "properties": {
        "state": {"enum": ["active", "deprecated", "retired"]},
        "introduced_in": {"$ref": "#/$defs/version"},
        "deprecated_in": {
          "anyOf": [{"$ref": "#/$defs/version"}, {"type": "null"}]
        },
        "replacement_code": {
          "anyOf": [{"$ref": "#/$defs/code"}, {"type": "null"}]
        }
      },
      "allOf": [
        {
          "if": {"properties": {"state": {"const": "active"}}, "required": ["state"]},
          "then": {
            "properties": {
              "deprecated_in": {"type": "null"},
              "replacement_code": {"type": "null"}
            }
          }
        },
        {
          "if": {
            "properties": {"state": {"enum": ["deprecated", "retired"]}},
            "required": ["state"]
          },
          "then": {"properties": {"deprecated_in": {"$ref": "#/$defs/version"}}}
        }
      ]
    },
    "safeDetailField": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "type",
        "required",
        "maximum_length",
        "maximum_value",
        "allowed_values",
        "privacy",
        "description"
      ],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$",
          "maxLength": 48
        },
        "type": {
          "enum": ["boolean", "u16", "u32", "u64-decimal", "identifier", "text", "enum"]
        },
        "required": {"type": "boolean"},
        "maximum_length": {
          "type": ["integer", "null"],
          "minimum": 1,
          "maximum": 256
        },
        "maximum_value": {
          "anyOf": [
            {"type": "integer", "minimum": 0, "maximum": 4294967295},
            {"type": "string", "pattern": "^(0|[1-9][0-9]{0,19})$", "maxLength": 20},
            {"type": "null"}
          ]
        },
        "allowed_values": {
          "type": "array",
          "maxItems": 32,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/identifier"}
        },
        "privacy": {"enum": ["public", "public-summary"]},
        "description": {"type": "string", "minLength": 1, "maxLength": 160}
      },
      "allOf": [
        {
          "if": {"properties": {"type": {"const": "boolean"}}, "required": ["type"]},
          "then": {
            "properties": {
              "maximum_length": {"type": "null"},
              "maximum_value": {"type": "null"},
              "allowed_values": {"maxItems": 0}
            }
          }
        },
        {
          "if": {"properties": {"type": {"enum": ["u16", "u32"]}}, "required": ["type"]},
          "then": {
            "properties": {
              "maximum_length": {"type": "null"},
              "maximum_value": {"type": "integer"},
              "allowed_values": {"maxItems": 0}
            }
          }
        },
        {
          "if": {"properties": {"type": {"const": "u64-decimal"}}, "required": ["type"]},
          "then": {
            "properties": {
              "maximum_length": {"type": "null"},
              "maximum_value": {
                "type": "string",
                "pattern": "^(0|[1-9][0-9]{0,19})$",
                "maxLength": 20
              },
              "allowed_values": {"maxItems": 0}
            }
          }
        },
        {
          "if": {"properties": {"type": {"enum": ["identifier", "text"]}}, "required": ["type"]},
          "then": {
            "properties": {
              "maximum_length": {"type": "integer"},
              "maximum_value": {"type": "null"},
              "allowed_values": {"maxItems": 0}
            }
          }
        },
        {
          "if": {"properties": {"type": {"const": "enum"}}, "required": ["type"]},
          "then": {
            "properties": {
              "maximum_length": {"type": "null"},
              "maximum_value": {"type": "null"},
              "allowed_values": {"minItems": 1}
            }
          }
        }
      ]
    },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "class",
        "severity",
        "retry_policy",
        "side_effect_certainty_policy",
        "remediation_id",
        "safe_detail_fields",
        "lifecycle",
        "owner",
        "technical_cause",
        "user_explanation",
        "privacy",
        "docs_path"
      ],
      "properties": {
        "code": {"$ref": "#/$defs/code"},
        "class": {
          "enum": [
            "protocol",
            "request",
            "ownership",
            "generation",
            "profile",
            "queue",
            "deadline",
            "transport",
            "persistence",
            "service",
            "kernel",
            "integration",
            "internal"
          ]
        },
        "severity": {"enum": ["info", "warning", "error", "critical"]},
        "retry_policy": {
          "enum": ["never", "bounded-backoff", "after-remediation", "outcome-lookup-only"]
        },
        "side_effect_certainty_policy": {
          "enum": ["not-applicable", "must-be-none", "runtime-reported", "possible", "partial"]
        },
        "remediation_id": {"$ref": "#/$defs/identifier"},
        "safe_detail_fields": {
          "type": "array",
          "maxItems": 12,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/safeDetailField"}
        },
        "lifecycle": {"$ref": "#/$defs/lifecycle"},
        "owner": {"enum": ["kernel", "bridge", "sdk", "integration", "packaging", "tooling"]},
        "technical_cause": {"$ref": "#/$defs/summary"},
        "user_explanation": {"$ref": "#/$defs/summary"},
        "privacy": {"enum": ["public", "public-summary"]},
        "docs_path": {"$ref": "#/$defs/docsPath"}
      }
    }
  }
}
