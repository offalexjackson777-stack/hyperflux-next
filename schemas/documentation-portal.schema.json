{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hyperflux.dev/schemas/documentation-portal-v2.json",
  "title": "HyperFlux documentation portal registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["$schema", "schema", "site", "navigation", "routes"],
  "properties": {
    "$schema": {"const": "../schemas/documentation-portal.schema.json"},
    "schema": {"const": "hyperflux-documentation-portal-v2"},
    "site": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "description", "publication_state", "canonical_url", "repository_url", "language", "social_image"],
      "properties": {
        "title": {"const": "HyperFlux Next"},
        "description": {"type": "string", "minLength": 1, "maxLength": 180},
        "publication_state": {"const": "public-pages-pre-release"},
        "canonical_url": {"type": "string", "format": "uri", "pattern": "^https://.*/$"},
        "repository_url": {"type": "string", "format": "uri", "pattern": "^https://github\\.com/"},
        "language": {"const": "en"},
        "social_image": {"type": "string", "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+\\.png$"}
      }
    },
    "navigation": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {"$ref": "#/$defs/navigation"}
    },
    "routes": {
      "type": "array",
      "minItems": 8,
      "maxItems": 48,
      "items": {"$ref": "#/$defs/route"}
    }
  },
  "$defs": {
    "identifier": {"type": "string", "pattern": "^[a-z][a-z0-9-]{0,63}$"},
    "navigation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "description", "primary_label", "landing_route", "routes"],
      "properties": {
        "id": {"enum": ["users", "devices", "developers", "maintainers"]},
        "title": {"type": "string", "minLength": 1, "maxLength": 48},
        "description": {"type": "string", "minLength": 1, "maxLength": 180},
        "primary_label": {"type": "string", "minLength": 1, "maxLength": 20},
        "landing_route": {"$ref": "#/$defs/identifier"},
        "routes": {"type": "array", "minItems": 1, "maxItems": 16, "uniqueItems": true, "items": {"$ref": "#/$defs/identifier"}}
      }
    },
    "route": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "path", "title", "summary", "source", "kind", "renderer", "audience", "search_terms"],
      "properties": {
        "id": {"$ref": "#/$defs/identifier"},
        "path": {"type": "string", "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+\\.html$"},
        "title": {"type": "string", "minLength": 1, "maxLength": 80},
        "summary": {"type": "string", "minLength": 1, "maxLength": 180},
        "source": {"type": "string", "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"},
        "kind": {"enum": ["home", "guide", "concept", "reference", "book", "ledger"]},
        "renderer": {"enum": ["home", "markdown", "book", "reference", "coverage", "device-lab", "atlas", "state"]},
        "audience": {"enum": ["users", "devices", "developers", "maintainers"]},
        "search_terms": {"type": "array", "maxItems": 12, "uniqueItems": true, "items": {"type": "string", "minLength": 1, "maxLength": 80}}
      }
    }
  }
}
