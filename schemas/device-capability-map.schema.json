{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hyperflux.dev/schemas/device-capability-map-v1.json",
  "title": "Reviewed upstream method to semantic capability map",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "rules"],
  "properties": {
    "$schema": {"type": "string"},
    "schema": {"const": "hyperflux-device-capability-map-v1"},
    "rules": {
      "type": "array",
      "minItems": 1,
      "maxItems": 256,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "semantic_capability", "family", "access", "presentation", "methods", "required_hyperflux_capabilities"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z][a-z0-9-]+$"},
          "semantic_capability": {"type": "string", "pattern": "^[a-z][a-z0-9.-]+$"},
          "family": {"enum": ["identity", "telemetry", "power", "performance", "input", "lighting", "macros"]},
          "access": {"enum": ["read", "write", "read-write"]},
          "presentation": {"enum": ["status", "scalar", "enum", "toggle", "collection", "action", "lighting-frame", "effect"]},
          "methods": {"type": "array", "minItems": 1, "maxItems": 64, "uniqueItems": true, "items": {"type": "string", "pattern": "^[a-z][a-z0-9_]+$"}},
          "required_hyperflux_capabilities": {"type": "array", "minItems": 1, "maxItems": 8, "uniqueItems": true, "items": {"type": "string", "pattern": "^[a-z][a-z0-9.-]+$"}}
        }
      }
    }
  }
}
