{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hyperflux.dev/schemas/migration-ledger-v1.json",
  "title": "HyperFlux migration ledger",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "default_disposition", "entries"],
  "properties": {
    "$schema": {"type": "string"},
    "schema": {"const": "hyperflux-migration-ledger-v1"},
    "default_disposition": {"const": "REJECT_UNTIL_REVIEWED"},
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "component", "disposition", "status", "sources", "destination_owner", "rationale"],
        "properties": {
          "id": {"type": "string", "pattern": "^HFX-MIG-[0-9]{3}$"},
          "component": {"type": "string", "minLength": 1},
          "disposition": {
            "enum": ["REIMPLEMENT", "REIMPLEMENT_AND_GENERATE", "REIMPLEMENT_WITH_PINNED_IMPORT", "MIGRATE_AFTER_REVIEW", "SPECIFICATION_ONLY", "TEST_REFERENCE", "RESEARCH_LINK", "REJECT"]
          },
          "status": {"enum": ["PENDING_REVIEW", "IN_PROGRESS", "ACCEPTED", "REJECTED"]},
          "sources": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
          "destination_owner": {"type": "string", "minLength": 1},
          "rationale": {"type": "string", "minLength": 1}
        }
      }
    }
  }
}

