{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hyperflux.dev/schemas/distribution-packages-v1.json",
  "title": "HyperFlux distribution package contract",
  "type": "object",
  "additionalProperties": false,
  "required": ["$schema", "schema", "metadata", "targets"],
  "properties": {
    "$schema": {"const": "../schemas/distribution-packages.schema.json"},
    "schema": {"const": "hyperflux-distribution-packages-v1"},
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["description", "licenses"],
      "properties": {
        "description": {
          "type": "string",
          "minLength": 1,
          "maxLength": 160,
          "pattern": "^[^\\u0000-\\u001f\\u007f]+$"
        },
        "licenses": {
          "type": "array",
          "minItems": 1,
          "maxItems": 8,
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9.+-]{0,63}$"}
        }
      }
    },
    "targets": {
      "type": "object",
      "additionalProperties": false,
      "required": ["arch", "debian", "rpm"],
      "properties": {
        "arch": {"$ref": "#/$defs/target"},
        "debian": {"$ref": "#/$defs/target"},
        "rpm": {"$ref": "#/$defs/target"}
      }
    }
  },
  "$defs": {
    "packageName": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9+_.() >=~-]{0,95}$"
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "architectures",
        "dependency_roles",
        "optional_dependencies",
        "conflicts",
        "python_discovery_path"
      ],
      "properties": {
        "architectures": {
          "type": "object",
          "minProperties": 1,
          "maxProperties": 8,
          "propertyNames": {"pattern": "^[A-Za-z0-9_.-]{1,127}$"},
          "additionalProperties": {"type": "string", "pattern": "^[A-Za-z0-9_.-]{1,31}$"}
        },
        "dependency_roles": {
          "type": "object",
          "additionalProperties": false,
          "required": ["dkms", "c-runtime", "compiler-runtime", "python", "service-manager", "device-manager"],
          "properties": {
            "dkms": {"$ref": "#/$defs/packageName"},
            "c-runtime": {"$ref": "#/$defs/packageName"},
            "compiler-runtime": {"$ref": "#/$defs/packageName"},
            "python": {"$ref": "#/$defs/packageName"},
            "service-manager": {"$ref": "#/$defs/packageName"},
            "device-manager": {"$ref": "#/$defs/packageName"}
          }
        },
        "optional_dependencies": {
          "type": "array",
          "maxItems": 16,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["package", "purpose"],
            "properties": {
              "package": {"$ref": "#/$defs/packageName"},
              "purpose": {
                "type": "string",
                "minLength": 1,
                "maxLength": 120,
                "pattern": "^[^\\u0000-\\u001f\\u007f]+$"
              }
            }
          }
        },
        "conflicts": {
          "type": "array",
          "maxItems": 16,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/packageName"}
        },
        "python_discovery_path": {
          "type": "string",
          "pattern": "^/usr/.+\\.pth$",
          "maxLength": 192
        }
      }
    }
  }
}
