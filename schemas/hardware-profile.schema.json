{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hyperflux.dev/schemas/hardware-profile-v1.json",
  "title": "Composable HyperFlux hardware profile",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "profile_id", "revision", "kind", "device_kind", "identity", "capabilities", "evidence_claims", "restrictions"],
  "properties": {
    "$schema": {"type": "string"},
    "schema": {"const": "hyperflux-hardware-profile-v1"},
    "profile_id": {"type": "string", "pattern": "^(receiver|child|surface)\\.[a-z0-9.-]+$"},
    "revision": {"type": "integer", "minimum": 1},
    "kind": {"enum": ["receiver", "child", "surface"]},
    "device_kind": {"enum": ["receiver", "mat", "mouse", "keyboard"]},
    "identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["manufacturer", "model_name", "authority"],
      "properties": {
        "manufacturer": {"type": "string", "minLength": 1},
        "model_name": {"type": "string", "minLength": 1},
        "authority": {"enum": ["usb", "paired-product-id", "reviewed-metadata"]},
        "vendor_id": {"type": "integer", "minimum": 0, "maximum": 65535},
        "product_id": {"type": "integer", "minimum": 0, "maximum": 65535},
        "variant_key": {"type": "string"}
      }
    },
    "compatibility": {"type": "object"},
    "transport": {"$ref": "#/$defs/transport"},
    "presentation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["upstream_id", "owner", "project_version", "source_commit", "model_key", "layout_key", "transport_variant"],
      "properties": {
        "upstream_id": {"type": "string", "pattern": "^[a-z][a-z0-9-]{0,63}$"},
        "owner": {"type": "string", "minLength": 1, "maxLength": 64},
        "project_version": {"type": "string", "minLength": 1, "maxLength": 64},
        "source_commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
        "model_key": {"type": "string", "pattern": "^[a-z][a-z0-9_]{0,127}$"},
        "layout_key": {
          "oneOf": [
            {"type": "null"},
            {"type": "string", "pattern": "^[a-z][a-z0-9_]{0,127}$"}
          ]
        },
        "transport_variant": {"enum": ["wireless", "wired", "bluetooth"]}
      }
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "support_level", "evidence_claims"],
        "properties": {
          "id": {"type": "string"},
          "support_level": {"enum": ["candidate", "identified", "read-only", "telemetry-qualified", "lighting-qualified", "settings-qualified", "pairing-qualified", "production-qualified"]},
          "evidence_claims": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}}
        }
      }
    },
    "evidence_claims": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
    "restrictions": {"type": "array", "items": {"type": "string", "minLength": 1}}
  },
  "$defs": {
    "transport": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "backend": {"type": "string", "minLength": 1},
        "backend_id": {"type": "integer", "minimum": 1, "maximum": 4294967295},
        "maximum_targets": {"type": "integer", "minimum": 1, "maximum": 65535},
        "generation_bound": {"type": "boolean"},
        "application_raw_frames": {"type": "boolean"},
        "lighting": {"$ref": "#/$defs/lighting"},
        "passive": {"$ref": "#/$defs/passive"}
      }
    },
    "lighting": {
      "type": "object",
      "additionalProperties": false,
      "required": ["physical_led_count", "application_slot_count", "carrier_count", "rows", "columns", "application_index_to_carrier"],
      "properties": {
        "physical_led_count": {"type": "integer", "minimum": 1, "maximum": 65535},
        "application_slot_count": {"type": "integer", "minimum": 1, "maximum": 65535},
        "carrier_count": {"type": "integer", "minimum": 1, "maximum": 65535},
        "rows": {"type": "integer", "minimum": 1, "maximum": 65535},
        "columns": {"type": "integer", "minimum": 1, "maximum": 65535},
        "application_index_to_carrier": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "integer", "minimum": 0, "maximum": 65535}
        }
      }
    },
    "passive": {
      "type": "object",
      "additionalProperties": false,
      "required": ["endpoint_lane", "battery_encoding", "contact", "route", "report_implies_route_available"],
      "properties": {
        "endpoint_lane": {"enum": ["pointer", "keyboard"]},
        "battery_encoding": {"enum": ["linear-255"]},
        "contact": {
          "oneOf": [
            {"type": "null"},
            {"$ref": "#/$defs/contact-decoder"}
          ]
        },
        "route": {"$ref": "#/$defs/route-decoder"},
        "report_implies_route_available": {"type": "boolean"}
      }
    },
    "contact-decoder": {
      "type": "object",
      "additionalProperties": false,
      "required": ["off_mat", "on_mat"],
      "properties": {
        "off_mat": {"$ref": "#/$defs/raw-values"},
        "on_mat": {"$ref": "#/$defs/raw-values"}
      }
    },
    "route-decoder": {
      "type": "object",
      "additionalProperties": false,
      "required": ["available", "unavailable"],
      "properties": {
        "available": {"$ref": "#/$defs/raw-values"},
        "unavailable": {"$ref": "#/$defs/raw-values"}
      }
    },
    "raw-values": {
      "type": "array",
      "uniqueItems": true,
      "items": {"type": "integer", "minimum": 0, "maximum": 4294967295}
    }
  },
  "allOf": [
    {
      "if": {"properties": {"kind": {"const": "child"}}, "required": ["kind"]},
      "then": {"required": ["compatibility", "transport", "presentation"]},
      "else": {"not": {"required": ["presentation"]}}
    }
  ]
}
