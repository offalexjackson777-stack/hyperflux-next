{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hyperflux.dev/schemas/capability-catalog-v1.json",
  "title": "HyperFlux semantic capability catalog",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "capabilities"],
  "properties": {
    "$schema": {"type": "string"},
    "schema": {"const": "hyperflux-capability-catalog-v1"},
    "capabilities": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "summary", "access", "owner", "profile_kinds"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z][a-z0-9.-]+$"},
          "summary": {"type": "string", "minLength": 1},
          "access": {"enum": ["read", "write"]},
          "owner": {"enum": ["kernel", "bridge", "sdk", "integration"]},
          "resource": {"type": ["string", "null"]},
          "profile_kinds": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {"enum": ["receiver", "child", "surface"]}
          }
        }
      }
    }
  }
}
