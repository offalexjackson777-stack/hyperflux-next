{
  "$schema": "../schemas/integration-catalog.schema.json",
  "schema": "hyperflux-integration-catalog-v1",
  "upstreams": [
    {
      "id": "openrazer",
      "name": "OpenRazer",
      "repository": "https://github.com/openrazer/openrazer.git",
      "version": "3.12.1-41-g6820f9d",
      "commit": "6820f9da169d354bc7e6e93a0aa8683a6bb75792",
      "license_expression": "GPL-2.0-or-later AND CC-BY-SA-4.0",
      "api_contract": "org.razer 3.x metadata and D-Bus vocabulary",
      "uses": ["compatibility-contract", "metadata-import"],
      "build_network_access": false
    },
    {
      "id": "openrgb",
      "name": "OpenRGB",
      "repository": "https://github.com/CalcProgrammer1/OpenRGB.git",
      "version": "1.0rc3",
      "commit": "6fbcf62d7694e7b92fd0a5884b40b92984fbd1b0",
      "license_expression": "GPL-2.0-only",
      "api_contract": "OpenRGB plugin API 4",
      "uses": ["effect-engine", "model-layout-registry", "plugin-build-contract"],
      "build_network_access": false
    },
    {
      "id": "polychromatic",
      "name": "Polychromatic",
      "repository": "https://github.com/polychromatic/polychromatic.git",
      "version": "0.9.7-7-g716737b",
      "commit": "716737bf444ab7e962f4d3b7a5188b2f07c0c4a1",
      "license_expression": "GPL-3.0-only",
      "api_contract": "Polychromatic 0.9 native backend contract",
      "uses": ["backend-contract", "presentation-reference"],
      "build_network_access": false
    }
  ],
  "adapters": [
    {
      "id": "openrazer-compatibility",
      "application": "OpenRazer-compatible clients",
      "kind": "compatibility-service",
      "status": "planned",
      "upstream_ids": ["openrazer"],
      "sdk_protocol_versions": [5],
      "feature_families": ["inventory", "lighting", "ownership", "telemetry"],
      "transport_access": "sdk-only",
      "unrelated_device_policy": "preserve",
      "coexistence_policy": "private-explicit-service-only",
      "owns": ["private compatibility service lifecycle", "qualified method translation"],
      "must_not_own": ["official org.razer daemon identity", "raw receiver transport", "unrelated OpenRazer devices"]
    },
    {
      "id": "openrgb-native",
      "application": "OpenRGB",
      "kind": "native-plugin",
      "status": "in-progress",
      "upstream_ids": ["openrgb"],
      "sdk_protocol_versions": [5],
      "feature_families": ["effects", "inventory", "lighting", "ownership", "presentation", "telemetry"],
      "transport_access": "sdk-only",
      "unrelated_device_policy": "preserve",
      "coexistence_policy": "application-plugin",
      "owns": ["OpenRGB contract adaptation", "OpenRGB controller lifecycle", "tested OpenRGB view model"],
      "must_not_own": ["effect mathematics", "raw receiver transport", "receiver qualification", "unrelated OpenRGB devices"]
    },
    {
      "id": "polychromatic-native",
      "application": "Polychromatic",
      "kind": "native-backend",
      "status": "planned",
      "upstream_ids": ["openrazer", "polychromatic"],
      "sdk_protocol_versions": [5],
      "feature_families": ["inventory", "lighting", "ownership", "presentation", "telemetry"],
      "transport_access": "sdk-only",
      "unrelated_device_policy": "preserve",
      "coexistence_policy": "native-backend-beside-existing",
      "owns": ["HyperFlux backend presentation", "Polychromatic contract adaptation", "tested Polychromatic view model"],
      "must_not_own": ["official OpenRazer backend", "raw receiver transport", "receiver qualification", "unrelated Polychromatic devices"]
    }
  ]
}
